# ============================================================================
# DigiPOSE Enterprise ERP & PoS System (.NET 10 / SQL Server / React / Next.js)
# Official .gitignore Blueprint
# ============================================================================

# ── Build & Compilation Artifacts ──
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bld/
[Pp]ublish/
publish/

# ── Database Files ──
*.mdf
*.ldf
*.ndf
*.db
*.sqlite
*.sqlite3

# ── User File Uploads & Local Media ──
source/DigiPOSE/wwwroot/uploads/*
!source/DigiPOSE/wwwroot/uploads/.gitkeep

# ── Environment & Secret Isolation ──
*.env
*.env.*
!*.env.example
!.env.example
appsettings.Local.json
appsettings.Production.json
appsettings.Development.Secret.json
!appsettings.json
!appsettings.Development.json
!appsettings.example.json

# ── Secrets & Certificates ──
*.pfx
*.p12
*.key
*.pem
*.cer
*.crt

# ── Client-Side Libraries & Node Dependencies ──
**/wwwroot/lib/*
!**/wwwroot/lib/.gitkeep
node_modules/
.next/
out/
dist/

# ── NuGet Packages ──
*.nupkg
*.snupkg
**/packages/
project.lock.json
project.fragment.lock.json
artifacts/

# ── Visual Studio / VS Code / JetBrains Rider ──
.vs/
.vscode/
.idea/
*.user
*.suo
*.userosscache
*.sln.docstates
*.rsuser
*.DotSettings.user
launchSettings.json

# ── MSBuild & Logs ──
*.log
msbuild*.wrn
msbuild*.err
msbuild*.svclog

# ── Test Results & Code Coverage ──
[Tt]est[Rr]esult*/
[Dd]ebug[Pp]ublic/
TestResults/
coverage*.xml
coverage*.json
*.coverage
*.coveragexml

# ── OS Generated Files ──
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
