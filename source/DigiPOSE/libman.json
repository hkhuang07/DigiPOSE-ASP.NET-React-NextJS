{
  "version": "1.0",
  "defaultProvider": "cdnjs",
  "libraries": [
    {
      "library": "bootstrap@5.3.3",
      "destination": "wwwroot/lib/bootstrap/",
      "files": [
        "js/bootstrap.bundle.min.js",
        "css/bootstrap.min.css"
      ]
    },
    {
      "library": "jquery@3.7.1",
      "destination": "wwwroot/lib/jquery",
      "files": [
        "jquery.min.js"
      ]
    },
    {
      "library": "font-awesome@6.5.1",
      "destination": "wwwroot/lib/font-awesome"
    },
    {
      "library": "jszip@3.10.1",
      "destination": "wwwroot/lib/datatables",
      "files": [
        "jszip.min.js"
      ]
    },
    {
      "library": "datatables.net@1.13.8",
      "destination": "wwwroot/lib/datatables",
      "files": [
        "jquery.dataTables.min.js"
      ]
    },
    {
      "library": "datatables.net-bs5@1.13.8",
      "destination": "wwwroot/lib/datatables",
      "files": [
        "dataTables.bootstrap5.min.css",
        "dataTables.bootstrap5.min.js"
      ]
    },
    {
      "library": "datatables.net-buttons-bs5@2.4.2",
      "destination": "wwwroot/lib/datatables",
      "files": [
        "buttons.bootstrap5.min.css",
        "buttons.bootstrap5.min.js"
      ]
    },
    {
      "library": "datatables.net-buttons@2.4.2",
      "destination": "wwwroot/lib/datatables",
      "files": [
        "js/dataTables.buttons.min.js",
        "js/buttons.html5.min.js"
      ]
    }
  ]
}