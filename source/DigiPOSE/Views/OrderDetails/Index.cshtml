@model IEnumerable<DigiPOSE.Models.OrderDetail>
@{ ViewData["Title"] = "Order Line Items"; }
<div class="cyber-panel">
    <div class="cyber-panel-header">
        <div class="cyber-panel-title"><i class="fa-solid fa-list-ol"></i> ORDER LINE ITEMS</div>
        <div class="cyber-panel-sub">[SALES MODULE] // ORDER DETAIL LINES</div>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <button type="button" class="btn-cyber-success btn-show-modal" data-url="@Url.Action("Create", "OrderDetails")"><i class="fa-solid fa-plus me-1"></i> ADD LINE</button>
        <div style="font-family:'Roboto Mono'; font-size:0.85rem; color:#00E5FF; white-space:nowrap;">TOTAL LINES: <strong id="totalRecordsCount" style="color:#FFF; font-family:'VT323'; font-size:1.3rem;">--</strong></div>
    </div>
    <div class="table-responsive">
        <table id="datatable" class="table-cyber w-100">
            <thead>
                <tr>
                    <th style="width:5%; text-align:center; white-space:nowrap;">#</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.OrderId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.ProductName)</th>
                    <th style="white-space:nowrap; text-align:right;">@Html.DisplayNameFor(model => model.Quantity)</th>
                    <th style="white-space:nowrap; text-align:right;">@Html.DisplayNameFor(model => model.UnitPrice)</th>
                    <th style="white-space:nowrap; text-align:right;">@Html.DisplayNameFor(model => model.TotalAmount)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.IsFree)</th>
                    <th style="width:120px; text-align:center; white-space:nowrap;">ACTIONS</th>
                </tr>
            </thead>
        </table>
    </div>
</div>
<div class="modal fade modal-cyber" id="globalModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" style="max-width:720px;" id="globalModalContainer"></div>
</div>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/lib/datatables/js/jquery.dataTables.min.js"></script>
    <script src="~/lib/datatables/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function(){
            var table = $('#datatable').DataTable({
                serverSide: true,
                processing: true,
                filter: true,
                ajax: {
                    url: '@Url.Action("Index_LoadData", "OrderDetails")',
                    type: "POST",
                    dataType: "JSON"
                },
                columns: [
                    { data: null, name: null, sortable: false, render: (d, t, r, meta) => meta.row + meta.settings._iDisplayStart + 1 },
                    { data: 'orderId', name: 'OrderId', render: d => `<span style="color:#FFF; font-family:'VT323'; font-size:1.1rem;">#${d}</span>` },
                    { data: 'productName', name: 'ProductName', render: d => `<span style="color:#A0C0CE; font-family:'Rajdhani'; font-weight:600;">${d}</span>` },
                    { data: 'quantity', name: 'Quantity', render: d => `<span style="color:#00FF66; font-family:'VT323'; font-size:1.2rem; float:right;">${d}</span>` },
                    { 
                        data: 'unitPrice', 
                        name: 'UnitPrice', 
                        render: d => `<span style="color:#FFB000; font-family:'VT323'; font-size:1.1rem; float:right;">${$.fn.dataTable.render.number(',', '.', 0, '').display(d)}</span>` 
                    },
                    { 
                        data: 'totalAmount', 
                        name: 'TotalAmount', 
                        render: d => `<span style="color:#00FF66; font-family:'VT323'; font-size:1.1rem; float:right;">${$.fn.dataTable.render.number(',', '.', 0, '').display(d)}</span>` 
                    },
                    { 
                        data: 'isFree', 
                        name: 'IsFree', 
                        render: d => d ? `<span class="badge bg-success">FREE</span>` : ''
                    },
                    { 
                        data: null, 
                        searchable: false, 
                        orderable: false, 
                        render: function (d, t, r) { 
                            var detailsUrl = '@Url.Action("Details", "OrderDetails")/' + r.orderDetailId;
                            var editUrl = '@Url.Action("Edit", "OrderDetails")/' + r.orderDetailId;
                            var deleteUrl = '@Url.Action("Delete", "OrderDetails")/' + r.orderDetailId;
                            return '<div style="text-align:center;">'
                                 + '<button type="button" class="btn-cyber-info btn-show-modal" data-url="' + detailsUrl + '" style="padding:4px 8px; font-size:0.75rem; border-color:#00E5FF; color:#00E5FF;"><i class="fa-solid fa-circle-info"></i></button> '
                                 + '<button type="button" class="btn-cyber-primary btn-show-modal" data-url="' + editUrl + '" style="padding:4px 8px; font-size:0.75rem; border-color:#FFB000; color:#FFB000;"><i class="fa-solid fa-pen-to-square"></i></button> ' 
                                 + '<button type="button" class="btn-cyber-danger btn-show-modal" data-url="' + deleteUrl + '" style="padding:4px 8px; font-size:0.75rem;"><i class="fa-solid fa-trash"></i></button>'
                                 + '</div>'; 
                        } 
                    }                        
                ],
                drawCallback: function (settings) {
                    var api = this.api();
                    var json = api.ajax.json();
                    if (json && json.recordsTotal !== undefined) {
                        $('#totalRecordsCount').text(json.recordsTotal);
                    }
                }
            });   
        });
    </script>
}

