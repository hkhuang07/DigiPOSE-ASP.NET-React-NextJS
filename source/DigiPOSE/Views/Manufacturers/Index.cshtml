@model IEnumerable<DigiPOSE.Models.Manufacturer>
@{ ViewData["Title"] = "Manufacturer"; }

<div class="cyber-panel">
    <div class="cyber-panel-header">
        <div class="cyber-panel-title"><i class="fa-solid fa-industry"></i> MANUFACTURER</div>
        <div class="cyber-panel-sub">[DIGIPOSE ERP] // MANUFACTURER REGISTRY</div>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <button type="button" class="btn-cyber-success btn-show-modal" data-url="@Url.Action("Create", "Manufacturers")">
            <i class="fa-solid fa-plus me-1"></i> ADD NEW
        </button>
        <div style="font-family:'Roboto Mono'; font-size:0.85rem; color:#00E5FF; white-space:nowrap;">
            TOTAL RECORDS: <strong id="totalRecordsCount" style="color:#FFF; font-family:'VT323'; font-size:1.3rem;">--</strong>
        </div>
    </div>
    <div class="table-responsive">
        <table id="datatable" class="table-cyber w-100">
            <thead>
                <tr>
                    <th style="width:5%; text-align:center; white-space:nowrap;">#</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.ManufacturerName)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.Slug)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.ImageUrl)</th>
                    <th style="width:100px; text-align:center; white-space:nowrap;">@Html.DisplayNameFor(model => model.IsActive)</th>
                    <th style="width:120px; text-align:center; white-space:nowrap;">ACTIONS</th>
                </tr>
            </thead>
        </table>
    </div>
</div>
<div class="modal fade modal-cyber" id="globalModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" style="max-width:620px;" id="globalModalContainer"></div>
</div>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/lib/datatables/js/jquery.dataTables.min.js"></script>
    <script src="~/lib/datatables/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function(){
            var table = $('#datatable').DataTable({
                serverSide: true,
                processing: true,
                filter: true,
                ajax: {
                    url: '@Url.Action("Index_LoadData", "Manufacturers")',
                    type: "POST",
                    dataType: "JSON"
                },
                columns: [
                    { data: null, name: null, sortable: false, render: (d, t, r, meta) => meta.row + meta.settings._iDisplayStart + 1 },
                    { data: 'manufacturerName', name: 'ManufacturerName', render: d => `<div style="color:#A0C0CE; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:180px;" title="${d}">${d}</div>` },
                    { data: 'slug', name: 'Slug', render: d => `<div style="color:#A0C0CE; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:180px;" title="${d}">${d}</div>` },
                    { 
                        data: 'imageUrl', 
                        name: 'ImageUrl', 
                        render: d => d ? `<img src="/uploads/manufacturers/${d}" alt="Logo" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px;" />` : '' 
                    },
                    { 
                        data: 'isActive', 
                        name: 'IsActive',
                        render: (d, t, r) => {
                            var antiForgery = $('input[name="__RequestVerificationToken"]').val() || '';
                            return `<form class="toggle-active-form" action="/Manufacturers/ToggleActive/${r.manufacturerId}" method="post" style="display:inline; text-align:center;">
                                        <input name="__RequestVerificationToken" type="hidden" value="${antiForgery}" />
                                        <button type="submit" class="badge ${d ? "bg-success" : "bg-secondary"} border-0" style="cursor:pointer; font-size:0.75rem; padding:4px 8px;" title="Click to toggle status">
                                            ${d ? "ACTIVE" : "INACTIVE"}
                                        </button>
                                    </form>`;
                        }
                    },                            
                    { 
                        data: null, 
                        searchable: false, 
                        orderable: false, 
                        render: function (d, t, r) { 
                            var detailsUrl = '@Url.Action("Details", "Manufacturers")/' + r.manufacturerId;
                            var editUrl = '@Url.Action("Edit", "Manufacturers")/' + r.manufacturerId;
                            var deleteUrl = '@Url.Action("Delete", "Manufacturers")/' + r.manufacturerId;
                            return '<div style="text-align:center;">'
                                 + '<button type="button" class="btn-cyber-info btn-show-modal" data-url="' + detailsUrl + '" style="padding:4px 8px; font-size:0.75rem; border-color:#00E5FF; color:#00E5FF;"><i class="fa-solid fa-circle-info"></i></button> '
                                 + '<button type="button" class="btn-cyber-primary btn-show-modal" data-url="' + editUrl + '" style="padding:4px 8px; font-size:0.75rem; border-color:#FFB000; color:#FFB000;"><i class="fa-solid fa-pen-to-square"></i></button> ' 
                                 + '<button type="button" class="btn-cyber-danger btn-show-modal" data-url="' + deleteUrl + '" style="padding:4px 8px; font-size:0.75rem;"><i class="fa-solid fa-trash"></i></button>'
                                 + '</div>'; 
                        } 
                    }                        
                ],
                drawCallback: function (settings) {
                    var api = this.api();
                    var json = api.ajax.json();
                    if (json && json.recordsTotal !== undefined) {
                        $('#totalRecordsCount').text(json.recordsTotal);
                    }
                }
            });   
        });

        $(document).on('shown.bs.modal', '#globalModal', function () {
            var descEl = document.querySelector('#Description');
            if (descEl && !descEl.classList.contains('ck-initialized')) {
                ClassicEditor
                    .create(descEl)
                    .then(editor => {
                        descEl.classList.add('ck-initialized');
                        $(descEl).closest('form').off('submit.ckeditor').on('submit.ckeditor', function () {
                            descEl.value = editor.getData();
                        });
                    })
                    .catch(err => console.error('CKEditor initialization error:', err));
            }
        }); 
    </script>
}

