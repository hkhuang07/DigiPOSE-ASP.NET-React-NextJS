@model DigiPOSE.Models.Manufacturer
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-industry text-cyan me-2"></i> @(Model.ManufacturerId == 0 ? "ADD NEW" : "EDIT") MANUFACTURER</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="@(Model.ManufacturerId == 0 ? "Create" : "Edit")" asp-controller="Manufacturers" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ManufacturerId" />
        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-family:'Roboto Mono'; font-size:0.85rem;"></div>
            <div class="mb-3">
                <label asp-for="ManufacturerName" class="form-cyber-label"></label>
                <input asp-for="ManufacturerName" class="form-control form-cyber-control" />
                <span asp-validation-for="ManufacturerName" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Slug" class="form-cyber-label"></label>
                <input asp-for="Slug" class="form-control form-cyber-control" placeholder="Leave empty to auto-generate slug from category name" />
                <span asp-validation-for="Slug" class="text-danger" style="font-family: 'Roboto Mono'; font-size: 0.8rem;"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="ContactPerson" class="form-cyber-label"></label>
                    <input asp-for="ContactPerson" class="form-control form-cyber-control" placeholder="Contact person name" />
                    <span asp-validation-for="ContactPerson" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Phone" class="form-cyber-label"></label>
                    <input asp-for="Phone" class="form-control form-cyber-control" placeholder="Phone number" />
                    <span asp-validation-for="Phone" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-cyber-label"></label>
                    <input asp-for="Email" type="email" class="form-control form-cyber-control" placeholder="Email address" />
                    <span asp-validation-for="Email" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="TaxCode" class="form-cyber-label"></label>
                    <input asp-for="TaxCode" class="form-control form-cyber-control" placeholder="Tax identification code" />
                    <span asp-validation-for="TaxCode" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Address" class="form-cyber-label"></label>
                <input asp-for="Address" class="form-control form-cyber-control" placeholder="Company address" />
                <span asp-validation-for="Address" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="LogoUrl" class="form-cyber-label"></label>
                    <input asp-for="LogoUrl" class="form-control form-cyber-control" placeholder="Image URL" />
                    <span asp-validation-for="LogoUrl" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Website" class="form-cyber-label"></label>
                    <input asp-for="Website" class="form-control form-cyber-control" placeholder="https://example.com" />
                    <span asp-validation-for="Website" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-cyber-label"></label>
                <textarea asp-for="Description" class="form-control form-cyber-control" rows="2" placeholder="Manufacturer notes or details"></textarea>
                <span asp-validation-for="Description" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="mb-3 d-flex align-items-center gap-3">
                <label asp-for="IsActive" class="form-cyber-label mb-0"></label>
                <input asp-for="IsActive" type="checkbox" class="form-check-input form-check-cyber" />
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
            <button type="submit" class="btn-cyber-success"><i class="fa-solid fa-floppy-disk me-1"></i> SAVE</button>
        </div>
    </form>
</div>
