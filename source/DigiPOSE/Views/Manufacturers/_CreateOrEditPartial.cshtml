@model DigiPOSE.Models.Manufacturer
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-industry text-cyan me-2"></i> @(Model.ManufacturerId == 0 ? "ADD NEW" : "EDIT") MANUFACTURER</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="@(Model.ManufacturerId == 0 ? "Create" : "Edit")" asp-controller="Manufacturers" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ManufacturerId" />
        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-family:'Roboto Mono'; font-size:0.85rem;"></div>
            <div class="mb-3">
                <label asp-for="ManufacturerName" class="form-cyber-label">NAME</label>
                <input asp-for="ManufacturerName" class="form-control form-cyber-control" />
                <span asp-validation-for="ManufacturerName" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="mb-3">
                <label asp-for="LogoUrl" class="form-cyber-label">LOGO URL</label>
                <input asp-for="LogoUrl" class="form-control form-cyber-control" />
                <span asp-validation-for="LogoUrl" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
            <button type="submit" class="btn-cyber-success"><i class="fa-solid fa-floppy-disk me-1"></i> SAVE</button>
        </div>
    </form>
</div>
