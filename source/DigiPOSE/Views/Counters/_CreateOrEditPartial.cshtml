@model DigiPOSE.Models.Counter
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-desktop text-cyan me-2"></i> @(Model.CounterId == 0 ? "ADD NEW" : "EDIT") COUNTER</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="@(Model.CounterId == 0 ? "Create" : "Edit")" asp-controller="Counters" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CounterId" />
        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-family:'Roboto Mono'; font-size:0.85rem;"></div>
            <div class="mb-3">
                <label asp-for="BranchId" class="form-cyber-label">BRANCH <span style="color:#FF3333;">*</span></label>
                <select asp-for="BranchId" class="form-select form-cyber-control" asp-items="ViewBag.BranchId">
                    <option value="">-- SELECT BRANCH --</option>
                </select>
                <span asp-validation-for="BranchId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="mb-3">
                <label asp-for="CounterName" class="form-cyber-label">COUNTER NAME <span style="color:#FF3333;">*</span></label>
                <input asp-for="CounterName" class="form-control form-cyber-control" placeholder="e.g. Counter 01, POS-A" />
                <span asp-validation-for="CounterName" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
            <button type="submit" class="btn-cyber-success"><i class="fa-solid fa-floppy-disk me-1"></i> SAVE</button>
        </div>
    </form>
</div>
