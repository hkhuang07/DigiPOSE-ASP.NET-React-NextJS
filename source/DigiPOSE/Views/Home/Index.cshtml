@model DigiPOSE.Models.DashboardViewModel
@{
    ViewData["Title"] = "DigiPOSE Administrator Dashboard";
}

<div class="cyber-panel">
    <div class="cyber-panel-header">
        <div class="cyber-panel-title">
            <i class="fa-solid fa-gauge-high"></i> ADMINISTRATOR DASHBOARD
        </div>
        <div class="cyber-panel-sub">
            [DYNAMIC DATA ENGINE] // TOTAL RECORDS: <strong style="color:#00FF66;">@Model.TotalSystemRecords</strong> | TABLES ONLINE: <strong style="color:#00E5FF;">@Model.TotalTables</strong>
        </div>
    </div>

    <div class="row g-3 mb-4">
        @foreach (var mod in Model.Modules)
        {
            var borderColor = mod.ModuleId switch
            {
                "MOD-01" => "rgba(0, 229, 255, 0.4)",
                "MOD-02" => "rgba(0, 255, 102, 0.4)",
                "MOD-03" => "rgba(255, 176, 0, 0.4)",
                "MOD-04" => "rgba(240, 248, 255, 0.5)",
                _ => "rgba(0, 229, 255, 0.4)"
            };

            var accentColor = mod.ModuleId switch
            {
                "MOD-01" => "#00E5FF",
                "MOD-02" => "#00FF66",
                "MOD-03" => "#FFB000",
                "MOD-04" => "#F0F8FF",
                _ => "#00E5FF"
            };

            <div class="col-lg-3 col-md-6">
                <div class="hud-module-card" style="height: 145px; background: rgba(10, 10, 10, 0.9); border: 1px solid @borderColor; padding: 1.1rem; display: flex; flex-direction: column; justify-content: space-between; position: relative; backdrop-filter: blur(8px);">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-family:'Orbitron'; font-size: 0.8rem; font-weight: 700; color: @accentColor; text-transform: uppercase; letter-spacing: 1px;">
                            @mod.ModuleName
                        </span>
                        <span style="font-family:'Roboto Mono'; font-size: 0.65rem; background: rgba(0, 229, 255, 0.15); color: @accentColor; border: 1px solid @borderColor; padding: 2px 6px;">
                            @mod.ModuleId
                        </span>
                    </div>

                    <div style="display: flex; align-items: baseline; gap: 10px; margin: 4px 0;">
                        <span style="font-family:'VT323'; font-size: 2.5rem; color: #FFFFFF; line-height: 1; text-shadow: 0 0 10px @accentColor;">
                            @mod.TableCount.ToString("D2")
                        </span>
                        <span style="font-family:'Rajdhani'; font-size: 0.85rem; color: #A0C0CE; font-weight: 600; text-transform: uppercase;">
                            MANAGED TABLES
                        </span>
                    </div>

                    <div style="font-family:'Roboto Mono'; font-size: 0.72rem; color: #00FF66; display: flex; align-items: center; justify-content: space-between; border-top: 1px dashed rgba(255, 255, 255, 0.1); padding-top: 6px;">
                        <span><i class="fa-solid fa-database me-1"></i> Live Records:</span>
                        <strong style="color: #FFFFFF; font-family:'VT323'; font-size: 1.2rem;">@mod.TotalRecordCount</strong>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Dynamic Database Tables Directory -->
    <h5 style="font-family:'Orbitron'; color:#00E5FF; font-size:0.95rem; margin-bottom:1rem; text-transform: uppercase; letter-spacing: 1px;">
        <i class="fa-solid fa-network-wired me-2"></i> DYNAMIC DATABASE TABLES DIRECTORY (@Model.TotalTables ENTITIES)
    </h5>
    
    <div class="table-responsive">
        <table class="table-cyber">
            <thead>
                <tr>
                    <th>Module ID</th>
                    <th>Module Name</th>
                    <th>Entity Tables</th>
                    <th>Controller Link</th>
                    <th style="text-align: right;">Live Record Count</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var mod in Model.Modules)
                {
                    @foreach (var tbl in mod.Tables)
                    {
                        <tr>
                            <td><code>@mod.ModuleId</code></td>
                            <td><strong>@mod.ModuleName</strong></td>
                            <td><i class="fa-solid fa-table text-cyan me-2"></i>@tbl.TableName</td>
                            <td>
                                <a asp-controller="@tbl.ControllerName" asp-action="Index" style="color:#00E5FF; text-decoration:none; font-family:'Roboto Mono'; font-size:0.85rem;">
                                    <i class="fa-solid fa-arrow-up-right-from-square me-1"></i>/@tbl.ControllerName
                                </a>
                            </td>
                            <td style="text-align: right; font-family:'VT323'; font-size:1.3rem; color:#FFF;">
                                @tbl.RecordCount
                            </td>
                            <td>
                                <span class="hud-status-badge active"><i class="fa-solid fa-check"></i> @tbl.Status</span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
