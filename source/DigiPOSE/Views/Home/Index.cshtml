@{
    Layout = null; // No admin layout for the landing page
    ViewData["Title"] = "DigiPOSE - Enterprise ERP & POS System";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <!-- CSS Dependencies -->
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Rajdhani:wght@500;700&family=VT323&family=Roboto+Mono:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #000;
            color: #00E5FF;
            font-family: 'Roboto Mono', monospace;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }
        body::before {
            content: "";
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
            background-size: 100% 2px, 3px 100%;
            pointer-events: none;
            z-index: 9999;
        }
        
        /* Cyber Navbar */
        .cyber-nav {
            background: rgba(0, 0, 0, 0.85);
            border-bottom: 1px solid #00E5FF;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            backdrop-filter: blur(10px);
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1000;
        }
        .cyber-brand {
            font-family: 'Orbitron', sans-serif;
            font-weight: 700;
            font-size: 1.5rem;
            color: #00E5FF;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 0 0 10px rgba(0, 229, 255, 0.5);
            text-decoration: none;
        }
        .cyber-btn {
            background: transparent;
            color: #00FF66;
            border: 1px solid #00FF66;
            font-family: 'Orbitron', sans-serif;
            font-weight: bold;
            letter-spacing: 1px;
            padding: 8px 20px;
            text-transform: uppercase;
            text-decoration: none;
            transition: all 0.3s;
            cursor: pointer;
        }
        .cyber-btn:hover {
            background: #00FF66;
            color: #000;
            box-shadow: 0 0 15px #00FF66;
        }
        .cyber-btn-outline {
            color: #00E5FF;
            border: 1px solid #00E5FF;
        }
        .cyber-btn-outline:hover {
            background: #00E5FF;
            color: #000;
            box-shadow: 0 0 15px #00E5FF;
        }

        /* Hero Section */
        .hero-section {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding-top: 80px;
            background: radial-gradient(circle at center, rgba(0, 229, 255, 0.1) 0%, #000 70%);
            position: relative;
        }
        .hero-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 4.5rem;
            font-weight: 700;
            color: #FFF;
            text-shadow: 0 0 20px #00E5FF;
            margin-bottom: 20px;
            letter-spacing: 4px;
        }
        .hero-subtitle {
            font-family: 'VT323', monospace;
            font-size: 2rem;
            color: #00FF66;
            margin-bottom: 40px;
        }
        .reticle {
            position: absolute;
            color: #FFB000;
            font-weight: bold;
        }
        .reticle-tl { top: 20px; left: 20px; }
        .reticle-tr { top: 20px; right: 20px; }
        .reticle-bl { bottom: 20px; left: 20px; }
        .reticle-br { bottom: 20px; right: 20px; }

        /* Sections */
        .section-container {
            padding: 100px 15px;
            border-top: 1px solid rgba(0, 229, 255, 0.2);
            position: relative;
        }
        .section-header {
            font-family: 'Rajdhani', sans-serif;
            font-size: 3rem;
            font-weight: 700;
            color: #00E5FF;
            text-align: center;
            text-transform: uppercase;
            margin-bottom: 60px;
            letter-spacing: 3px;
        }
        
        /* Grid Cards */
        .feature-card {
            background: rgba(10, 10, 10, 0.8);
            border: 1px solid rgba(0, 229, 255, 0.3);
            padding: 30px;
            height: 100%;
            transition: all 0.3s;
            position: relative;
        }
        .feature-card:hover {
            border-color: #00E5FF;
            box-shadow: 0 0 20px rgba(0, 229, 255, 0.2) inset;
        }
        .feature-icon {
            font-size: 2.5rem;
            color: #FFB000;
            margin-bottom: 20px;
        }
        .feature-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.2rem;
            color: #FFF;
            margin-bottom: 15px;
        }
        .feature-desc {
            font-size: 0.9rem;
            color: #A0C0CE;
            line-height: 1.6;
        }

        /* Pricing Table */
        .price-card {
            background: rgba(0, 0, 0, 0.6);
            border: 1px solid #333;
            padding: 40px 30px;
            text-align: center;
            transition: all 0.3s;
        }
        .price-card.featured {
            border: 1px solid #00FF66;
            box-shadow: 0 0 20px rgba(0, 255, 102, 0.2);
            transform: scale(1.05);
            background: rgba(0, 255, 102, 0.05);
        }
        .price-title {
            font-family: 'Orbitron', sans-serif;
            color: #FFF;
            margin-bottom: 20px;
        }
        .price-value {
            font-family: 'VT323', monospace;
            font-size: 3.5rem;
            color: #00E5FF;
            margin-bottom: 30px;
        }
        .price-card.featured .price-value {
            color: #00FF66;
        }
        .price-list {
            list-style: none;
            padding: 0;
            margin: 0 0 30px 0;
            text-align: left;
            color: #A0C0CE;
        }
        .price-list li {
            margin-bottom: 12px;
            border-bottom: 1px dashed rgba(255,255,255,0.1);
            padding-bottom: 12px;
        }
        .price-list li i {
            color: #FFB000;
            margin-right: 10px;
        }

        /* Footer */
        .cyber-footer {
            background: #050505;
            border-top: 1px solid #00E5FF;
            padding: 40px 0;
            text-align: center;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>

    <!-- Navigation -->
    <nav class="cyber-nav">
        <a href="/" class="cyber-brand">
            <i class="fa-solid fa-microchip me-2"></i> DigiPOSE
        </a>
        <div>
            @if (ViewBag.IsAuthenticated == true)
            {
                <a href="/Home/DashboardRouter" class="cyber-btn"><i class="fa-solid fa-gauge-high"></i> ACCESS DASHBOARD</a>
            }
            else
            {
                <a href="/Auth/Login" class="cyber-btn cyber-btn-outline me-3"><i class="fa-solid fa-terminal"></i> LOGIN</a>
                <a href="/Auth/Register" class="cyber-btn"><i class="fa-solid fa-user-plus"></i> INITIALIZE</a>
            }
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-section">
        <span class="reticle reticle-tl">+</span>
        <span class="reticle reticle-tr">+</span>
        <span class="reticle reticle-bl">+</span>
        <span class="reticle reticle-br">+</span>
        
        <div class="container">
            <div style="font-family:'VT323'; color:#00E5FF; margin-bottom:10px;">> SYSTEM STATUS: ONLINE _</div>
            <h1 class="hero-title">ENTERPRISE<br/>RESOURCE GRID</h1>
            <div class="hero-subtitle">NEXT-GEN POINT OF SALE & INVENTORY ARCHITECTURE</div>
            
            <div class="mt-5">
                <a href="#pricing" class="cyber-btn me-3" style="font-size: 1.1rem; padding: 15px 40px;">
                    [ DEPLOY INSTANCE ]
                </a>
                <a href="#features" class="cyber-btn cyber-btn-outline" style="font-size: 1.1rem; padding: 15px 40px;">
                    [ SCAN FEATURES ]
                </a>
            </div>
            
            <div style="margin-top: 80px; font-size: 0.8rem; color: #666; letter-spacing: 2px;">
                POWERED BY ASP.NET CORE | SQL SERVER CLUSTER | BIOMETRIC SECURED
            </div>
        </div>
    </section>

    <!-- Core Modules Section -->
    <section id="features" class="section-container">
        <div class="container">
            <h2 class="section-header">CORE TELEMETRY MODULES</h2>
            <div class="row g-4">
                <div class="col-lg-3 col-md-6">
                    <div class="feature-card">
                        <i class="fa-solid fa-cash-register feature-icon text-cyan"></i>
                        <h3 class="feature-title">SMART P.O.S</h3>
                        <p class="feature-desc">High-speed transaction processing node. Supports offline queueing, multiple payment gateways, and real-time receipt generation.</p>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="feature-card">
                        <i class="fa-solid fa-warehouse feature-icon" style="color: #00FF66;"></i>
                        <h3 class="feature-title">WAREHOUSE</h3>
                        <p class="feature-desc">Dynamic inventory tracking. Automated stock vouchers, low-stock alerts, and multi-branch inventory transfers.</p>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="feature-card">
                        <i class="fa-solid fa-chart-line feature-icon text-warning"></i>
                        <h3 class="feature-title">FINANCE CRM</h3>
                        <p class="feature-desc">Deep-dive financial telemetry. Track cash flow, supplier debts, customer loyalty tiers, and invoice statuses.</p>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="feature-card">
                        <i class="fa-solid fa-shield-halved feature-icon" style="color: #FF3333;"></i>
                        <h3 class="feature-title">SECURE R.B.A.C</h3>
                        <p class="feature-desc">Military-grade Role-Based Access Control. Granular permissions strictly isolating operators from administrative core functions.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Pricing Section -->
    <section id="pricing" class="section-container" style="background: rgba(0,229,255,0.02);">
        <div class="container">
            <h2 class="section-header">DEPLOYMENT PROTOCOLS</h2>
            <div class="row justify-content-center g-4">
                <div class="col-lg-4 col-md-6">
                    <div class="price-card">
                        <h3 class="price-title">NODE.ALPHA</h3>
                        <div class="price-value">$49<span style="font-size:1rem; color:#666;">/MO</span></div>
                        <ul class="price-list">
                            <li><i class="fa-solid fa-check"></i> 1 Active Branch</li>
                            <li><i class="fa-solid fa-check"></i> 3 POS Operator Accounts</li>
                            <li><i class="fa-solid fa-check"></i> Standard Inventory</li>
                            <li><i class="fa-solid fa-xmark" style="color:#FF3333;"></i> No API Access</li>
                        </ul>
                        <a href="/Auth/Register" class="cyber-btn cyber-btn-outline w-100">INITIALIZE ALPHA</a>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6">
                    <div class="price-card featured">
                        <div style="color:#00FF66; font-size:0.8rem; margin-bottom:10px; font-weight:bold;">[ RECOMMENDED ]</div>
                        <h3 class="price-title">NODE.PRIME</h3>
                        <div class="price-value">$129<span style="font-size:1rem; color:#666;">/MO</span></div>
                        <ul class="price-list">
                            <li><i class="fa-solid fa-check"></i> Up to 5 Branches</li>
                            <li><i class="fa-solid fa-check"></i> Unlimited Accounts</li>
                            <li><i class="fa-solid fa-check"></i> Advanced Finance & CRM</li>
                            <li><i class="fa-solid fa-check"></i> 24/7 Priority Support</li>
                        </ul>
                        <a href="/Auth/Register" class="cyber-btn w-100">INITIALIZE PRIME</a>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6">
                    <div class="price-card">
                        <h3 class="price-title">NODE.OMEGA</h3>
                        <div class="price-value">CUSTOM</div>
                        <ul class="price-list">
                            <li><i class="fa-solid fa-check"></i> Unlimited Branches</li>
                            <li><i class="fa-solid fa-check"></i> Dedicated Cloud Server</li>
                            <li><i class="fa-solid fa-check"></i> Custom Hardware Integration</li>
                            <li><i class="fa-solid fa-check"></i> Full GraphQL/REST APIs</li>
                        </ul>
                        <a href="mailto:admin@digipose.com" class="cyber-btn cyber-btn-outline w-100">CONTACT HQ</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Footer -->
    <footer class="cyber-footer">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-md-start mb-3 mb-md-0">
                    <div style="font-family:'Orbitron'; font-size:1.2rem; font-weight:bold; color:#00E5FF;">DigiPOSE CORE</div>
                    <div style="color:#666; margin-top:5px;">&copy; 2026. ALL SYSTEMS NOMINAL.</div>
                </div>
                <div class="col-md-6 text-md-end">
                    <a href="#" style="color:#00E5FF; text-decoration:none; margin-left:15px;"><i class="fa-brands fa-github"></i> REPOSITORY</a>
                    <a href="#" style="color:#00E5FF; text-decoration:none; margin-left:15px;"><i class="fa-solid fa-shield"></i> SEC-OPS</a>
                    <a href="#" style="color:#00E5FF; text-decoration:none; margin-left:15px;"><i class="fa-solid fa-envelope"></i> COMMS</a>
                </div>
            </div>
        </div>
    </footer>

</body>
</html>
