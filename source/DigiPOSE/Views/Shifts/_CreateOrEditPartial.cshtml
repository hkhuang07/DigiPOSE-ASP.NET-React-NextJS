@model DigiPOSE.Models.Shift
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-calendar-check text-cyan me-2"></i> @(Model.ShiftId == 0 ? "ADD NEW" : "EDIT") SHIFT</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="@(Model.ShiftId == 0 ? "Create" : "Edit")" asp-controller="Shifts" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ShiftId" />
        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-family:'Roboto Mono'; font-size:0.85rem;"></div>
            <div class="row g-2">
                <div class="col-md-6 mb-2">
                    <label asp-for="UserId" class="form-cyber-label">@Html.DisplayNameFor(model => model.UserId) <span style="color:#FF3333;">*</span></label>
                    <select asp-for="UserId" class="form-select form-cyber-control" asp-items="ViewBag.UserId"><option value="">-- SELECT --</option></select>
                    <span asp-validation-for="UserId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="CounterId" class="form-cyber-label">@Html.DisplayNameFor(model => model.CounterId) <span style="color:#FF3333;">*</span></label>
                    <select asp-for="CounterId" class="form-select form-cyber-control" asp-items="ViewBag.CounterId"><option value="">-- SELECT --</option></select>
                    <span asp-validation-for="CounterId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="StatusId" class="form-cyber-label">@Html.DisplayNameFor(model => model.StatusId) <span style="color:#FF3333;">*</span></label>
                    <select asp-for="StatusId" class="form-select form-cyber-control" asp-items="ViewBag.StatusId"><option value="">-- SELECT --</option></select>
                    <span asp-validation-for="StatusId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="StartCash" class="form-cyber-label"></label>
                    <input asp-for="StartCash" class="form-control form-cyber-control" type="number" step="any" min="0" />
                    <span asp-validation-for="StartCash" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="StartTime" class="form-cyber-label">@Html.DisplayNameFor(model => model.StartTime) <span style="color:#FF3333;">*</span></label>
                    <input asp-for="StartTime" class="form-control form-cyber-control" type="datetime-local" />
                    <span asp-validation-for="StartTime" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="EndTime" class="form-cyber-label"></label>
                    <input asp-for="EndTime" class="form-control form-cyber-control" type="datetime-local" />
                    <span asp-validation-for="EndTime" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="EndCash" class="form-cyber-label"></label>
                    <input asp-for="EndCash" class="form-control form-cyber-control" type="number" step="any" min="0" />
                    <span asp-validation-for="EndCash" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
            <button type="submit" class="btn-cyber-success"><i class="fa-solid fa-floppy-disk me-1"></i> SAVE SHIFT</button>
        </div>
    </form>
</div>
