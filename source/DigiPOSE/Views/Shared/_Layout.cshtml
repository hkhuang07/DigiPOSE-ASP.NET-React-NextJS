<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DigiPOSE Cyber HUD ERP</title>
    
    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <!-- FontAwesome 6 Local Icons -->
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css" />
    <!-- Cyber-Cinematic Military HUD Custom CSS -->
    <link rel="stylesheet" href="~/css/cyber-hud.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div id="app-wrapper">
        <!-- ====================================================================
             TOP NAVBAR
             - Left Navbar: 3-bar hamburger icon (toggle sidebar), logo_main, Logoname
             - Right Navbar: Language, Dark/Light Mode, Notification, Profile
             ==================================================================== -->
        <header class="hud-navbar">
            <!-- Left Navbar -->
            <div class="hud-navbar-left">
                <button type="button" class="hud-toggle-btn" id="sidebarToggle" title="Toggle Sidebar Navigation">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <a class="hud-brand" asp-area="" asp-controller="Home" asp-action="Index" title="System Home">
                    <!-- logo_main SVG HUD Icon -->
                    <svg class="hud-logo-icon" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <polygon points="50,5 95,27 95,73 50,95 5,73 5,27" stroke="#00E5FF" stroke-width="4" fill="rgba(0, 229, 255, 0.1)"/>
                        <circle cx="50" cy="50" r="24" stroke="#00E5FF" stroke-width="3" stroke-dasharray="6 4"/>
                        <circle cx="50" cy="50" r="8" fill="#00FF66"/>
                        <line x1="50" y1="15" x2="50" y2="35" stroke="#00E5FF" stroke-width="3"/>
                        <line x1="50" y1="65" x2="50" y2="85" stroke="#00E5FF" stroke-width="3"/>
                        <line x1="15" y1="50" x2="35" y2="50" stroke="#00E5FF" stroke-width="3"/>
                        <line x1="65" y1="50" x2="85" y2="50" stroke="#00E5FF" stroke-width="3"/>
                    </svg>
                    <div class="hud-brand-title">
                        Digi<span>POSE</span> HUD <span class="hud-badge-ver">v1.0</span>
                    </div>
                </a>
            </div>

            <!-- Right Navbar Actions -->
            <div class="hud-navbar-right">
                <!-- Language Selector (Icon + Text) -->
                <button type="button" class="hud-lang-btn" id="langToggleBtn" title="Switch Language (English / Tiếng Việt)">
                    <i class="fa-solid fa-globe"></i>
                    <span id="langText">English</span>
                </button>

                <!-- Dark / Light Mode Switcher (Icon Only) -->
                <button type="button" class="hud-nav-icon-btn" id="themeToggleBtn" title="Toggle Dark (Void) / Light (Holo) Mode">
                    <i class="fa-solid fa-sun" id="themeIcon"></i>
                </button>

                <!-- Notification Dropdown (Icon Only + Red Badge Outside) -->
                <div class="dropdown hud-notif-wrapper">
                    <button class="hud-notif-btn" type="button" id="notifDropdown" data-bs-toggle="dropdown" aria-expanded="false" title="Notifications">
                        <i class="fa-solid fa-bell" style="font-size: 1.1rem; color: #FFFFFF;"></i>
                        <span class="hud-notif-badge" id="hudNotifBadge">3</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end hud-dropdown-menu" aria-labelledby="notifDropdown" id="hudNotifMenu">
                        <li><h6 class="dropdown-header text-cyan" style="color:#00E5FF; font-family:'Orbitron';">TELEMETRY ALERTS</h6></li>
                        <li><a class="dropdown-item" href="#"><i class="fa-solid fa-triangle-exclamation text-warning me-2"></i> SKU-109 inventory below minimum threshold</a></li>
                        <li><a class="dropdown-item" href="#"><i class="fa-solid fa-circle-check text-success me-2"></i> Work shift #8812 closed successfully</a></li>
                        <li><a class="dropdown-item" href="#"><i class="fa-solid fa-file-invoice text-info me-2"></i> 5 new tax invoices generated in session</a></li>
                    </ul>
                </div>

                <!-- Profile Dropdown (Single Caret Icon) -->
                <div class="dropdown">
                    <div class="hud-profile-trigger" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="hud-avatar-box">@(User.Identity?.Name != null && User.Identity.Name.Length >= 2 ? User.Identity.Name.Substring(0, 2).ToUpper() : "ADM")</div>
                        <div class="hud-user-info">
                            <span class="hud-user-name">@(User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "COMMANDER")</span>
                            <span class="hud-user-role">@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "SYSTEM ADMIN")</span>
                        </div>
                        <i class="fa-solid fa-caret-down text-cyan ms-2" id="hudProfileCaret" style="font-size: 0.75rem; transition: transform 0.2s ease;"></i>
                    </div>
                    <ul class="dropdown-menu dropdown-menu-end hud-dropdown-menu" aria-labelledby="profileDropdown">
                        <li><a class="dropdown-item" href="#"><i class="fa-solid fa-id-card me-2"></i> User Profile</a></li>
                        <li><a class="dropdown-item" href="#"><i class="fa-solid fa-sliders me-2"></i> System Settings</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" asp-area="" asp-controller="Auth" asp-action="Logout"><i class="fa-solid fa-power-off me-2"></i> Log Out</a></li>
                    </ul>
                </div>
            </div>
        </header>

        <!-- ====================================================================
             MAIN CONTAINER (LEFT SIDEBAR + MAIN CONTENT)
             Sidebar contains management links for all 26 tables categorized by module
             ==================================================================== -->
        <div class="hud-main-container">
            <!-- Left Sidebar -->
            <aside class="hud-sidebar" id="hudSidebar">
                @if (User.IsInRole("Super Admin") || User.IsInRole("Branch Manager") || User.IsInRole("POS Operator"))
                {
                    <div class="hud-menu-group">
                        <div class="hud-menu-category-title text-success">
                            <span><i class="fa-solid fa-cash-register me-1"></i> Point of Sale</span>
                            <i class="fa-solid fa-chevron-down text-success" style="font-size:0.6rem;"></i>
                        </div>
                        <ul class="hud-menu-list">
                            <li class="hud-menu-item">
                                <a class="hud-menu-link border border-success" asp-controller="POS" asp-action="Index" style="box-shadow: 0 0 10px rgba(0, 255, 102, 0.2);">
                                    <i class="fa-solid fa-desktop text-success"></i>
                                    <span class="hud-menu-text text-success" style="font-weight: bold;">Launch POS App</span>
                                    <span class="hud-menu-badge" style="background-color: #00FF66; color: black; border-color: #00FF66;">SYS</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                }

                <!-- MODULE 1: SYSTEM & IAM -->
                <div class="hud-menu-group">
                    <div class="hud-menu-category-title">
                        <span><i class="fa-solid fa-shield-halved me-1"></i> System & IAM</span>
                        <i class="fa-solid fa-chevron-down text-cyan" style="font-size:0.6rem;"></i>
                    </div>
                    <ul class="hud-menu-list">
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="Branches" asp-action="Index">
                                <i class="fa-solid fa-code-branch"></i>
                                <span class="hud-menu-text">Branches</span>
                                <span class="hud-menu-badge">TBL-01</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="Roles" asp-action="Index">
                                <i class="fa-solid fa-user-shield"></i>
                                <span class="hud-menu-text">Roles & Permissions</span>
                                <span class="hud-menu-badge">TBL-02</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="Users" asp-action="Index">
                                <i class="fa-solid fa-users-gear"></i>
                                <span class="hud-menu-text">User Accounts</span>
                                <span class="hud-menu-badge">TBL-03</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="Counters" asp-action="Index">
                                <i class="fa-solid fa-desktop"></i>
                                <span class="hud-menu-text">Counters</span>
                                <span class="hud-menu-badge">TBL-04</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="Shifts" asp-action="Index">
                                <i class="fa-solid fa-clock-rotate-left"></i>
                                <span class="hud-menu-text">Work Shifts</span>
                                <span class="hud-menu-badge">TBL-05</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="ShiftStatuses" asp-action="Index">
                                <i class="fa-solid fa-list-check"></i>
                                <span class="hud-menu-text">Shift Statuses</span>
                                <span class="hud-menu-badge">TBL-06</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- MODULE 2: PARTNERS & CRM -->
                <div class="hud-menu-group">
                    <div class="hud-menu-category-title">
                        <span><i class="fa-solid fa-handshake me-1"></i> Partners & CRM</span>
                        <i class="fa-solid fa-chevron-down text-cyan" style="font-size:0.6rem;"></i>
                    </div>
                    <ul class="hud-menu-list">
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="CustomerTypes" asp-action="Index">
                                <i class="fa-solid fa-layer-group"></i>
                                <span class="hud-menu-text">Customer Types</span>
                                <span class="hud-menu-badge">TBL-07</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="Customers" asp-action="Index">
                                <i class="fa-solid fa-address-book"></i>
                                <span class="hud-menu-text">Customers</span>
                                <span class="hud-menu-badge">TBL-08</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="Suppliers" asp-action="Index">
                                <i class="fa-solid fa-truck-field"></i>
                                <span class="hud-menu-text">Suppliers</span>
                                <span class="hud-menu-badge">TBL-09</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- MODULE 3: INVENTORY & CATALOG -->
                <div class="hud-menu-group">
                    <div class="hud-menu-category-title">
                        <span><i class="fa-solid fa-boxes-stacked me-1"></i> Inventory & Catalog</span>
                        <i class="fa-solid fa-chevron-down text-cyan" style="font-size:0.6rem;"></i>
                    </div>
                    <ul class="hud-menu-list">
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="Categories" asp-action="Index">
                                <i class="fa-solid fa-folder-tree"></i>
                                <span class="hud-menu-text">Categories</span>
                                <span class="hud-menu-badge">TBL-10</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="Units" asp-action="Index">
                                <i class="fa-solid fa-scale-balanced"></i>
                                <span class="hud-menu-text">Units</span>
                                <span class="hud-menu-badge">TBL-11</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="Manufacturers" asp-action="Index">
                                <i class="fa-solid fa-industry"></i>
                                <span class="hud-menu-text">Manufacturers</span>
                                <span class="hud-menu-badge">TBL-12</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="TaxTypes" asp-action="Index">
                                <i class="fa-solid fa-percent"></i>
                                <span class="hud-menu-text">Tax Types</span>
                                <span class="hud-menu-badge">TBL-13</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="ProductTypes" asp-action="Index">
                                <i class="fa-solid fa-tags"></i>
                                <span class="hud-menu-text">Product Types</span>
                                <span class="hud-menu-badge">TBL-14</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="ItemNatures" asp-action="Index">
                                <i class="fa-solid fa-dna"></i>
                                <span class="hud-menu-text">Item Natures</span>
                                <span class="hud-menu-badge">TBL-15</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="Products" asp-action="Index">
                                <i class="fa-solid fa-box-open"></i>
                                <span class="hud-menu-text">Products</span>
                                <span class="hud-menu-badge">TBL-16</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="ProductInventories" asp-action="Index">
                                <i class="fa-solid fa-warehouse"></i>
                                <span class="hud-menu-text">Product Inventories</span>
                                <span class="hud-menu-badge">TBL-17</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="StockVouchers" asp-action="Index">
                                <i class="fa-solid fa-file-export"></i>
                                <span class="hud-menu-text">Stock Vouchers</span>
                                <span class="hud-menu-badge">TBL-18</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="StockVoucherDetails" asp-action="Index">
                                <i class="fa-solid fa-file-lines"></i>
                                <span class="hud-menu-text">Stock Voucher Details</span>
                                <span class="hud-menu-badge">TBL-19</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- MODULE 4: SALES & BILLING -->
                <div class="hud-menu-group">
                    <div class="hud-menu-category-title">
                        <span><i class="fa-solid fa-cart-shopping me-1"></i> Sales & Billing</span>
                        <i class="fa-solid fa-chevron-down text-cyan" style="font-size:0.6rem;"></i>
                    </div>
                    <ul class="hud-menu-list">
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="OrderStatuses" asp-action="Index">
                                <i class="fa-solid fa-flag"></i>
                                <span class="hud-menu-text">Order Statuses</span>
                                <span class="hud-menu-badge">TBL-20</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="PaymentMethods" asp-action="Index">
                                <i class="fa-solid fa-credit-card"></i>
                                <span class="hud-menu-text">Payment Methods</span>
                                <span class="hud-menu-badge">TBL-21</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="Orders" asp-action="Index">
                                <i class="fa-solid fa-receipt"></i>
                                <span class="hud-menu-text">Sales Orders</span>
                                <span class="hud-menu-badge">TBL-22</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="OrderDetails" asp-action="Index">
                                <i class="fa-solid fa-list-ol"></i>
                                <span class="hud-menu-text">Order Details</span>
                                <span class="hud-menu-badge">TBL-23</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="InvoiceStatuses" asp-action="Index">
                                <i class="fa-solid fa-square-check"></i>
                                <span class="hud-menu-text">Invoice Statuses</span>
                                <span class="hud-menu-badge">TBL-24</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="InvoiceTypes" asp-action="Index">
                                <i class="fa-solid fa-file-invoice-dollar"></i>
                                <span class="hud-menu-text">Invoice Types</span>
                                <span class="hud-menu-badge">TBL-25</span>
                            </a>
                        </li>
                        <li class="hud-menu-item">
                            <a class="hud-menu-link" asp-controller="Invoices" asp-action="Index">
                                <i class="fa-solid fa-file-signature"></i>
                                <span class="hud-menu-text">Financial Invoices</span>
                                <span class="hud-menu-badge">TBL-26</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </aside>

            <!-- Main Content Container -->
            <main role="main" class="hud-main-content">
                @RenderBody()
            </main>
        </div>

        <!-- ====================================================================
             FOOTER TELEMETRY STRIP
             ==================================================================== -->
        <footer class="hud-footer">
            <div class="hud-footer-status">
                <span class="hud-ping-dot"></span>
                <span>SYSTEM STATUS: <strong style="color:#00FF66;">ONLINE</strong></span>
                <span>|</span>
                <span>SECURITY: <strong style="color:#00E5FF;">ZERO-TRUST ENCRYPTED</strong></span>
            </div>
            <div class="hud-footer-time">
                <i class="fa-solid fa-microchip me-1"></i>
                <span id="hudFooterClock">2026-07-19 02:00:00.00 UTC+7</span>
            </div>
        </footer>
    </div>

    <!-- Global AntiForgeryToken Provider -->
    <div style="display:none;" id="globalAntiforgeryContainer">
        @Html.AntiForgeryToken()
    </div>

    <!-- Shared Global Notification Modal -->
    @await Html.PartialAsync("_CyberNotificationModal")

    <!-- Scripts --> 
    <script src="~/lib/ckeditor5/ckeditor.js"></script>
    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/cyber-hud.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>