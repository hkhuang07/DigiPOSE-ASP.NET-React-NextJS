@model DigiPOSE.Models.ProductType
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-boxes-stacked text-cyan me-2"></i> PRODUCTTYPE DETAILS</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
        <table class="table-cyber" style="font-family:'Roboto Mono'; font-size:0.9rem;">
            <tr><td style="color:#00E5FF; width:35%;">@Html.DisplayNameFor(model => model.ProductTypeId)</td><td>@Model.ProductTypeId</td></tr>
            <tr><td style="color:#00E5FF; width:35%;">@Html.DisplayNameFor(model => model.TypeName)</td><td>@Model.TypeName</td></tr>
            <tr><td style="color:#00E5FF; width:35%;">@Html.DisplayNameFor(model => model.IsInventoryTracked)</td><td>@Model.IsInventoryTracked</td></tr>
            <tr><td style="color:#00E5FF;">TRACK INVENTORY</td><td><span class="badge @(Model.IsInventoryTracked ? "bg-info" : "bg-secondary")">@(Model.IsInventoryTracked ? "YES" : "NO")</span></td></tr>
            <tr><td style="color:#00E5FF;">STATUS</td><td><span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">@(Model.IsActive ? "ACTIVE" : "INACTIVE")</span></td></tr>
        </table>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CLOSE</button>
    </div>
</div>

