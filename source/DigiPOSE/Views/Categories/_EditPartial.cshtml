@model DigiPOSE.Models.Category

<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-pen-to-square text-cyan me-2"></i> EDIT CATEGORY DATA</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal" aria-label="Close">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>
    <form class="ajax-modal-form" asp-action="Edit" asp-controller="Categories" asp-route-id="@Model.CategoryId" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CategoryId" />
        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-family: 'Roboto Mono'; font-size: 0.85rem;"></div>

            <div class="mb-3">
                <label class="form-cyber-label">CATEGORY ID</label>
                <input value="#@Model.CategoryId.ToString("D4")" class="form-control form-cyber-control" disabled style="opacity:0.6;" />
            </div>
            <div class="mb-3">
                <label asp-for="CategoryName" class="form-cyber-label">CATEGORY NAME <span style="color:#FF3333;">*</span></label>
                <input asp-for="CategoryName" class="form-control form-cyber-control" placeholder="Enter category title..." />
                <span asp-validation-for="CategoryName" class="text-danger" style="font-family: 'Roboto Mono'; font-size: 0.8rem;"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Slug" class="form-cyber-label">SLUG (OPTIONAL)</label>
                <input asp-for="Slug" class="form-control form-cyber-control" placeholder="Leave empty to auto-generate slug from category name" />
                <span asp-validation-for="Slug" class="text-danger" style="font-family: 'Roboto Mono'; font-size: 0.8rem;"></span>
            </div>
            <div class="mb-2">
                <label asp-for="Description" class="form-cyber-label">DESCRIPTION (OPTIONAL)</label>
                <textarea asp-for="Description" class="form-control form-cyber-control" rows="3" placeholder="Enter description..."></textarea>
                <span asp-validation-for="Description" class="text-danger" style="font-family: 'Roboto Mono'; font-size: 0.8rem;"></span>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal" style="border-color: rgba(255,255,255,0.3); color:#FFF;">
                <i class="fa-solid fa-xmark me-1"></i> CANCEL
            </button>
            <button type="submit" class="btn-cyber-primary">
                <i class="fa-solid fa-floppy-disk me-1"></i> UPDATE CHANGES
            </button>
        </div>
    </form>
</div>
