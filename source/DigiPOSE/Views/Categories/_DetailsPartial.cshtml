@model DigiPOSE.Models.Category

<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-circle-info text-cyan me-2"></i> CATEGORY TELEMETRY INFO</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal" aria-label="Close">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>
    <div class="modal-body">
        <div style="background: rgba(0, 0, 0, 0.6); border: 1px solid rgba(0, 229, 255, 0.3); padding: 1.25rem;">
            <div class="row mb-3 align-items-center">
                <div class="col-4 form-cyber-label">Category ID:</div>
                <div class="col-8" style="font-family:'VT323'; font-size:1.4rem; color:#FFF;">#@Model.CategoryId.ToString("D4")</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4 form-cyber-label">Category Name:</div>
                <div class="col-8" style="font-family:'Rajdhani'; font-size:1.1rem; font-weight:bold; color:#00FF66;">@Model.CategoryName</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4 form-cyber-label">Slug:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.95rem; color:#00E5FF;">@(string.IsNullOrEmpty(Model.Slug) ? "N/A" : Model.Slug)</div>
            </div>
            <div class="row align-items-center">
                <div class="col-4 form-cyber-label">Description:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#A0C0CE;">@(string.IsNullOrEmpty(Model.Description) ? "No detailed description provided." : Model.Description)</div>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal">
            <i class="fa-solid fa-check me-1"></i> CLOSE TELEMETRY
        </button>
    </div>
</div>
