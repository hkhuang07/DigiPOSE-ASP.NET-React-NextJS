@model IEnumerable<DigiPOSE.Models.Category>
@{
    ViewData["Title"] = "Category Directory";
}

<div class="cyber-panel">
    <div class="cyber-panel-header">
        <div class="cyber-panel-title">
            <i class="fa-solid fa-folder-tree"></i> CATEGORY DIRECTORY
        </div>
        <div class="cyber-panel-sub">
            [INVENTORY & CATALOG MODULE] // DYNAMIC AJAX MODAL ENGINE
        </div>
    </div>

    <!-- Top Action Toolbar -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <button type="button" class="btn-cyber-success btn-show-modal" data-url="@Url.Action("Create", "Categories")">
            <i class="fa-solid fa-plus me-1"></i> ADD NEW 
        </button>
        <div style="font-family:'Roboto Mono'; font-size: 0.85rem; color: #00E5FF; white-space: nowrap;">
            TOTAL CATEGORIES: <strong style="color:#FFF; font-family:'VT323'; font-size:1.3rem;">@Model.Count()</strong>
        </div>
    </div>

    <!-- Categories List Table -->
    <div class="table-responsive">
        <table class="table-cyber">
            <thead>
                <tr>
                    <th style="width: 5%; text-align: center; white-space: nowrap;">#</th>
                    <th style="width: 22%; white-space: nowrap;">@Html.DisplayNameFor(model => model.CategoryName)</th>
                    <th style="width: 18%; white-space: nowrap;">@Html.DisplayNameFor(model => model.Slug)</th>
                    <th style="width: 35%; white-space: nowrap;">@Html.DisplayNameFor(model => model.Description)</th>
                    <th style="width: 20%; text-align: center; white-space: nowrap;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @{ int idx = 1; }
                @foreach (var item in Model) {
                    <tr>
                        <td style="font-family:'VT323'; font-size:1.2rem; color:#00E5FF; text-align: center; white-space: nowrap;">@idx.ToString("D2")</td>
                        <td style="white-space: nowrap;">
                            <strong style="color: #FFFFFF; font-family:'Rajdhani'; font-size:1.05rem;">
                                <i class="fa-solid fa-folder me-2 text-cyan"></i>@item.CategoryName
                            </strong>
                        </td>
                        <td style="white-space: nowrap;">
                            <span style="color: #00E5FF; font-family:'Roboto Mono'; font-size:0.9rem;">
                                @(string.IsNullOrEmpty(item.Slug) ? "N/A" : item.Slug)
                            </span>
                        </td>
                        <td style="color: #A0C0CE; font-family:'Roboto Mono'; font-size:0.85rem; max-width: 320px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@item.Description">
                            @(string.IsNullOrEmpty(item.Description) ? "N/A" : item.Description)
                        </td>
                        <td style="text-align: center; white-space: nowrap;">
                            <button type="button" class="btn-cyber-primary btn-show-modal me-1" style="padding: 4px 10px; font-size: 0.75rem; border-color:#00FF66; color:#00FF66;"
                                    data-url="@Url.Action("Details", "Categories", new { id = item.CategoryId })">
                                <i class="fa-solid fa-eye"></i> INFO
                            </button>
                            <button type="button" class="btn-cyber-primary btn-show-modal me-1" style="padding: 4px 10px; font-size: 0.75rem;" 
                                    data-url="@Url.Action("Edit", "Categories", new { id = item.CategoryId })">
                                <i class="fa-solid fa-pen-to-square"></i> EDIT
                            </button>
                            <button type="button" class="btn-cyber-danger btn-show-modal" style="padding: 4px 10px; font-size: 0.75rem;"
                                    data-url="@Url.Action("Delete", "Categories", new { id = item.CategoryId })">
                                <i class="fa-solid fa-trash"></i> DELETE
                            </button>
                        </td>
                    </tr>
                    idx++;
                }
            </tbody>
        </table>
    </div>
</div>

<!-- SINGLE GENERIC GLOBAL MODAL CONTAINER -->
<div class="modal fade modal-cyber" id="globalModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 620px;" id="globalModalContainer">
        <!-- DYNAMIC PARTIAL VIEWS LOADED VIA AJAX -->
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}