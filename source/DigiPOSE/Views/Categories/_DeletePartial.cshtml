@model DigiPOSE.Models.Category

<div class="modal-content" style="border-color: rgba(255, 51, 51, 0.6);">
    <div class="modal-header" style="border-bottom-color: rgba(255, 51, 51, 0.4);">
        <h5 class="modal-title" style="color: #FF3333;"><i class="fa-solid fa-triangle-exclamation me-2"></i> CONFIRM REMOVAL</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal" aria-label="Close" style="border-color: rgba(255, 51, 51, 0.4); color: #FF3333;">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>
    <form class="ajax-modal-form" asp-action="Delete" asp-controller="Categories" asp-route-id="@Model.CategoryId" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CategoryId" />
        <div class="modal-body">
            <div style="background: rgba(255, 51, 51, 0.08); border: 1px solid rgba(255, 51, 51, 0.4); padding: 1rem; margin-bottom: 1rem;">
                <div style="font-family:'Orbitron'; font-size:0.85rem; color:#FF3333; font-weight:bold; margin-bottom:0.5rem; white-space:nowrap;">
                    <i class="fa-solid fa-radiation me-2"></i> CONFIRM DELETION RECORD
                </div>
                <p style="font-family:'Rajdhani'; font-size:0.95rem; color:#FFF; margin:0;">
                    Are you sure you want to permanently remove category <strong style="color:#FF3333;">@Model.CategoryName</strong>?
                </p>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal" style="border-color: rgba(255,255,255,0.3); color:#FFF;">
                <i class="fa-solid fa-xmark me-1"></i> CANCEL
            </button>
            <button type="submit" class="btn-cyber-danger">
                <i class="fa-solid fa-trash me-1"></i> PERMANENTLY DELETE
            </button>
        </div>
    </form>
</div>
