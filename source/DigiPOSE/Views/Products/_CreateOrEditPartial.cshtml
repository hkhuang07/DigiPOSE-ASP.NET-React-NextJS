@model DigiPOSE.Models.Product
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-box-open text-cyan me-2"></i> @(Model.ProductId == 0 ? "ADD NEW PRODUCT" : "EDIT PRODUCT")</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    @* NOTE: Use id="productForm" so the special multipart AJAX handler in Products/Index.cshtml kicks in *@
    <form id="productForm" class="ajax-modal-form" asp-action="@(Model.ProductId == 0 ? "Create" : "Edit")" asp-controller="Products" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ProductId" />
        <input type="hidden" asp-for="ImageUrl" /> <!-- Giữ lại đường dẫn ảnh cũ nếu không đổi -->
        <input type="hidden" asp-for="RowVersion" />
        
        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-family:'Roboto Mono'; font-size:0.85rem;"></div>
            <div class="row g-2">
                <div class="col-md-4 mb-2">
                    <label asp-for="SKU" class="form-cyber-label">@Html.DisplayNameFor(model => model.SKU) <span style="color:#FF3333;">*</span></label>
                    <input asp-for="SKU" class="form-control form-cyber-control" placeholder="e.g. SKU-001" />
                    <span asp-validation-for="SKU" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-4 mb-2">
                    <label asp-for="Barcode" class="form-cyber-label"></label>
                    <input asp-for="Barcode" class="form-control form-cyber-control" placeholder="Barcode" />
                    <span asp-validation-for="Barcode" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-4 mb-2">
                    <label asp-for="BasePrice" class="form-cyber-label">@Html.DisplayNameFor(model => model.BasePrice) <span style="color:#FF3333;">*</span></label>
                    <input asp-for="BasePrice" class="form-control form-cyber-control" type="number" step="any" min="0" />
                    <span asp-validation-for="BasePrice" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="CostPrice" class="form-cyber-label"></label>
                    <input asp-for="CostPrice" class="form-control form-cyber-control" type="number" step="any" min="0" />
                    <span asp-validation-for="CostPrice" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-12 mb-2">
                    <label asp-for="ProductName" class="form-cyber-label">@Html.DisplayNameFor(model => model.ProductName) <span style="color:#FF3333;">*</span></label>
                    <input asp-for="ProductName" class="form-control form-cyber-control" placeholder="Full product name" id="productNameInput" />
                    <span asp-validation-for="ProductName" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-12 mb-2">
                    <label asp-for="Description" class="form-cyber-label"></label>
                    <textarea asp-for="Description" class="form-control form-cyber-control" rows="2" placeholder="Product details / specifications"></textarea>
                    <span asp-validation-for="Description" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="CategoryId" class="form-cyber-label">@Html.DisplayNameFor(model => model.CategoryId) <span style="color:#FF3333;">*</span></label>
                    <select asp-for="CategoryId" class="form-select form-cyber-control" asp-items="ViewBag.CategoryId"><option value="">-- SELECT --</option></select>
                    <span asp-validation-for="CategoryId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="ProductTypeId" class="form-cyber-label">@Html.DisplayNameFor(model => model.ProductTypeId) <span style="color:#FF3333;">*</span></label>
                    <select asp-for="ProductTypeId" class="form-select form-cyber-control" asp-items="ViewBag.ProductTypeId"><option value="">-- SELECT --</option></select>
                    <span asp-validation-for="ProductTypeId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="UnitId" class="form-cyber-label">@Html.DisplayNameFor(model => model.UnitId) <span style="color:#FF3333;">*</span></label>
                    <select asp-for="UnitId" class="form-select form-cyber-control" asp-items="ViewBag.UnitId"><option value="">-- SELECT --</option></select>
                    <span asp-validation-for="UnitId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="TaxTypeId" class="form-cyber-label">@Html.DisplayNameFor(model => model.TaxTypeId) <span style="color:#FF3333;">*</span></label>
                    <select asp-for="TaxTypeId" class="form-select form-cyber-control" asp-items="ViewBag.TaxTypeId"><option value="">-- SELECT --</option></select>
                    <span asp-validation-for="TaxTypeId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-12 mb-2">
                    <label asp-for="ManufacturerId" class="form-cyber-label"></label>
                    <select asp-for="ManufacturerId" class="form-select form-cyber-control" asp-items="ViewBag.ManufacturerId"><option value="">-- NONE --</option></select>
                    <span asp-validation-for="ManufacturerId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="ImageUpload" class="form-cyber-label"></label>
                        <!-- Preview old image if available -->
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mb-2 d-flex align-items-center gap-2">
                            <img src="~/uploads/products/@Model.ImageUrl" width="60" height="60" class="img-thumbnail bg-dark" style="object-fit:cover;" />
                            <small class="text-muted">Current image (Leave blank if desired)</small>
                            </div>
                        }
                    <input asp-for="ImageUpload" type="file" accept="image/jpeg,image/png,image/webp" class="form-control form-cyber-control" />
                    <span asp-validation-for="ImageUpload" class="text-danger"></span>
                </div>
                
                <div class="col-12 mb-2 d-flex align-items-center gap-3">
                    <label asp-for="IsActive" class="form-cyber-label mb-0"></label>
                    <input asp-for="IsActive" type="checkbox" class="form-check-input form-check-cyber" />
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-cancel" data-bs-dismiss="modal" style="border-top: 1px solid aliceblue !important; border-bottom: 1px solid aliceblue !important; border-left: none !important; border-right: none !important; color: aliceblue !important; background: #222222 !important;"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
            <button type="submit" class="btn-cyber-success"><i class="fa-solid fa-floppy-disk me-1"></i> SAVE PRODUCT</button>
        </div>
    </form>
</div>

