@model IEnumerable<DigiPOSE.Models.Product>
@{ ViewData["Title"] = "Product Catalog"; }

<div class="cyber-panel">
    <div class="cyber-panel-header">
        <div class="cyber-panel-title"><i class="fa-solid fa-box-open"></i> PRODUCT CATALOG</div>
        <div class="cyber-panel-sub">[INVENTORY MODULE] // PRODUCT REGISTRY</div>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <button type="button" class="btn-cyber-success btn-show-modal" data-url="@Url.Action("Create", "Products")">
            <i class="fa-solid fa-plus me-1"></i> ADD NEW PRODUCT
        </button>
        <div style="font-family:'Roboto Mono'; font-size:0.85rem; color:#00E5FF; white-space:nowrap;">
            TOTAL: <strong style="color:#FFF; font-family:'VT323'; font-size:1.3rem;">@Model.Count()</strong>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table-cyber">
            <thead>
                <tr>
                    <th style="width:5%; text-align:center; white-space:nowrap;">#</th>
                    <th style="width:50px; white-space:nowrap;">@Html.DisplayNameFor(model => model.ImageUrl)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.SKU)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.ProductName)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.CategoryId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.UnitId)</th>
                    <th style="white-space:nowrap; text-align:right;">@Html.DisplayNameFor(model => model.BasePrice)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.IsActive)</th>
                    <th style="width:120px; text-align:center; white-space:nowrap;">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @{ int idx = 1; }
                @foreach (var item in Model) {
                    <tr>
                        <td style="font-family:'VT323'; font-size:1.2rem; color:#00E5FF; text-align:center; white-space:nowrap;">@idx.ToString("D2")</td>
                        <td style="padding:4px; white-space:nowrap;">
                            @if (!string.IsNullOrEmpty(item.ImageUrl)) {
                                <img src="@item.ImageUrl" alt="@item.ProductName" style="width:38px; height:38px; object-fit:cover; border:1px solid #00E5FF; border-radius:4px;" />
                            } else {
                                <div style="width:38px; height:38px; background:#0A0A0A; border:1px dashed #444; border-radius:4px; display:flex; align-items:center; justify-content:center;">
                                    <i class="fa-solid fa-image" style="color:#444; font-size:0.75rem;"></i>
                                </div>
                            }
                        </td>
                        <td style="font-family:'Roboto Mono'; font-size:0.85rem; color:#00E5FF; white-space:nowrap;">@item.SKU</td>
                        <td style="font-family:'Rajdhani'; font-weight:600; color:#FFF; white-space:nowrap; max-width:200px; overflow:hidden; text-overflow:ellipsis;" title="@item.ProductName">@item.ProductName</td>
                        <td style="color:#A0C0CE; white-space:nowrap;">@item.Category?.CategoryName</td>
                        <td style="color:#A0C0CE; white-space:nowrap;">@item.Unit?.UnitName</td>
                        <td style="color:#00FF66; font-family:'VT323'; font-size:1.1rem; text-align:right; white-space:nowrap;">@string.Format("{0:N0}", item.BasePrice)</td>
                        <td style="text-align:center; white-space:nowrap;">
                            <form class="toggle-active-form" asp-action="ToggleActive" asp-controller="Products" asp-route-id="@item.ProductId" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="badge @(item.IsActive ? "bg-success" : "bg-secondary") border-0" style="cursor:pointer; font-size:0.75rem; padding:4px 8px;" title="Click to toggle status">
                                    @(item.IsActive ? "ACTIVE" : "INACTIVE")
                                </button>
                            </form>
                        </td>
                        <td style="text-align:center; white-space:nowrap;">
                            <button type="button" class="btn-cyber-primary btn-show-modal" style="padding:4px 8px; font-size:0.75rem;" title="Details"
                                    data-url="@Url.Action("Details", "Products", new { id = item.ProductId })"><i class="fa-solid fa-eye"></i></button>
                            <button type="button" class="btn-cyber-primary btn-show-modal" style="padding:4px 8px; font-size:0.75rem; margin:0 2px; border-color:#FFB000; color:#FFB000;" title="Edit"
                                    data-url="@Url.Action("Edit", "Products", new { id = item.ProductId })"><i class="fa-solid fa-pen-to-square"></i></button>
                            <button type="button" class="btn-cyber-danger btn-show-modal" style="padding:4px 8px; font-size:0.75rem;" title="Delete"
                                    data-url="@Url.Action("Delete", "Products", new { id = item.ProductId })"><i class="fa-solid fa-trash"></i></button>
                        </td>
                    </tr>
                    idx++;
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade modal-cyber" id="globalModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" style="max-width:780px;" id="globalModalContainer"></div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
