@model DigiPOSE.Models.Branch
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-building text-cyan me-2"></i> BRANCH DETAILS</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
        <table class="table-cyber" style="font-family:'Roboto Mono'; font-size:0.9rem;">
            <tr><td style="color:#00E5FF; width:35%;">@Html.DisplayNameFor(model => model.BranchId)</td><td>@Model.BranchId</td></tr>
            <tr><td style="color:#00E5FF;">@Html.DisplayNameFor(model => model.BranchName)</td><td style="font-weight:600;">@Model.BranchName</td></tr>
            <tr><td style="color:#00E5FF;">SLUG</td><td>@(string.IsNullOrEmpty(Model.Slug) ? "N/A" : Model.Slug)</td></tr>
            <tr><td style="color:#00E5FF;">@Html.DisplayNameFor(model => model.Address)</td><td>@Model.Address</td></tr>
            <tr><td style="color:#00E5FF;">@Html.DisplayNameFor(model => model.ContactPhone)</td><td>@Model.ContactPhone</td></tr>
            <tr><td style="color:#00E5FF;">EMAIL</td><td>@(string.IsNullOrEmpty(Model.Email) ? "N/A" : Model.Email)</td></tr>
            <tr><td style="color:#00E5FF;">MANAGER NAME</td><td>@(string.IsNullOrEmpty(Model.ManagerName) ? "N/A" : Model.ManagerName)</td></tr>
            <tr><td style="color:#00E5FF;">NOTES</td><td>@(string.IsNullOrEmpty(Model.Notes) ? "N/A" : Model.Notes)</td></tr>
            <tr><td style="color:#00E5FF;">STATUS</td><td><span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">@(Model.IsActive ? "ACTIVE" : "INACTIVE")</span></td></tr>
        </table>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn-cyber-cancel" data-bs-dismiss="modal" style="border-top: 1px solid aliceblue !important; border-bottom: 1px solid aliceblue !important; border-left: none !important; border-right: none !important; color: aliceblue !important; background: #222222 !important;"><i class="fa-solid fa-xmark me-1"></i> CLOSE</button>
    </div>
</div>

