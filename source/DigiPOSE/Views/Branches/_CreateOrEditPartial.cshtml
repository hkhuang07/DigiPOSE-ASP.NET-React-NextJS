@model DigiPOSE.Models.Branch
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-layer-group text-cyan me-2"></i> @(Model.BranchId == 0 ? "ADD NEW" : "EDIT") BRANCH</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="@(Model.BranchId == 0 ? "Create" : "Edit")" asp-controller="Branches" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="BranchId" />
        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-family:'Roboto Mono'; font-size:0.85rem;"></div>
            <div class="mb-3">
                <label asp-for="BranchName" class="form-cyber-label"></label>
                <input asp-for="BranchName" class="form-control form-cyber-control" />
                <span asp-validation-for="BranchName" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Slug" class="form-cyber-label"></label>
                <input asp-for="Slug" class="form-control form-cyber-control" placeholder="Leave empty to auto-generate" />
                <span asp-validation-for="Slug" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Address" class="form-cyber-label"></label>
                <input asp-for="Address" class="form-control form-cyber-control" />
                <span asp-validation-for="Address" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="ContactPhone" class="form-cyber-label"></label>
                    <input asp-for="ContactPhone" class="form-control form-cyber-control" placeholder="Branch phone" />
                    <span asp-validation-for="ContactPhone" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-cyber-label"></label>
                    <input asp-for="Email" type="email" class="form-control form-cyber-control" placeholder="Branch email" />
                    <span asp-validation-for="Email" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="ManagerName" class="form-cyber-label"></label>
                <input asp-for="ManagerName" class="form-control form-cyber-control" placeholder="Branch manager full name" />
                <span asp-validation-for="ManagerName" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-cyber-label"></label>
                <textarea asp-for="Notes" class="form-control form-cyber-control" rows="2" placeholder="Branch details / notes"></textarea>
                <span asp-validation-for="Notes" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="mb-3 d-flex align-items-center gap-3">
                <label asp-for="IsActive" class="form-cyber-label mb-0"></label>
                <input asp-for="IsActive" type="checkbox" class="form-check-input form-check-cyber" />
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
            <button type="submit" class="btn-cyber-success"><i class="fa-solid fa-floppy-disk me-1"></i> SAVE</button>
        </div>
    </form>
</div>
