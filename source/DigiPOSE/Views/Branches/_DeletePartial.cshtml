@model DigiPOSE.Models.Branch
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-triangle-exclamation text-danger me-2"></i> CONFIRM DELETE</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="Delete" asp-controller="Branches" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.BranchId" />
        <div class="modal-body">
            <p style="font-family:'Roboto Mono'; color:#FF3333;">Are you sure you want to deactivate branch <strong style="color:#FFF;">@Model.BranchName</strong>?</p>
            <p style="font-family:'Roboto Mono'; font-size:0.8rem; color:#A0C0CE;">This action will perform a soft delete (IsActive = false). The record will be hidden from all lists.</p>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
            <button type="submit" class="btn-cyber-danger"><i class="fa-solid fa-trash me-1"></i> CONFIRM DELETE</button>
        </div>
    </form>
</div>
