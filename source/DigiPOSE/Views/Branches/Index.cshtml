@model IEnumerable<DigiPOSE.Models.Branch>
@{
    ViewData["Title"] = "Branch Management";
}

<div class="cyber-panel">
    <div class="cyber-panel-header">
        <div class="cyber-panel-title">
            <i class="fa-solid fa-building"></i> BRANCH MANAGEMENT
        </div>
        <div class="cyber-panel-sub">[ORGANIZATION MODULE] // BRANCH REGISTRY</div>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <button type="button" class="btn-cyber-success btn-show-modal" data-url="@Url.Action("Create", "Branches")">
            <i class="fa-solid fa-plus me-1"></i> ADD NEW BRANCH
        </button>
        <div style="font-family:'Roboto Mono'; font-size: 0.85rem; color: #00E5FF; white-space: nowrap;">
            TOTAL: <strong style="color:#FFF; font-family:'VT323'; font-size:1.3rem;">@Model.Count()</strong>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table-cyber">
            <thead>
                <tr>
                    <th style="width:5%; text-align:center; white-space:nowrap;">#</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.BranchName)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.Slug)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.Address)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.ContactPhone)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.IsActive)</th>
                    <th style="width:120px; text-align:center; white-space:nowrap;">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @{ int idx = 1; }
                @foreach (var item in Model) {
                    <tr>
                        <td style="font-family:'VT323'; font-size:1.2rem; color:#00E5FF; text-align:center; white-space:nowrap;">@idx.ToString("D2")</td>
                        <td style="font-family:'Rajdhani'; font-weight:600; color:#FFF; white-space:nowrap;">@item.BranchName</td>
                        <td style="font-family:'Roboto Mono'; font-size:0.85rem; color:#00E5FF; white-space:nowrap;">@(string.IsNullOrEmpty(item.Slug) ? "N/A" : item.Slug)</td>
                        <td style="color:#A0C0CE; max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="@item.Address">@item.Address</td>
                        <td style="color:#A0C0CE; white-space:nowrap;">@item.ContactPhone</td>
                        <td style="text-align:center; white-space:nowrap;">
                            <form class="toggle-active-form" asp-action="ToggleActive" asp-controller="Branches" asp-route-id="@item.BranchId" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="badge @(item.IsActive ? "bg-success" : "bg-secondary") border-0" style="cursor:pointer; font-size:0.75rem; padding:4px 8px;" title="Click to toggle status">
                                    @(item.IsActive ? "ACTIVE" : "INACTIVE")
                                </button>
                            </form>
                        </td>
                        <td style="text-align:center; white-space:nowrap;">
                            <button type="button" class="btn-cyber-primary btn-show-modal" style="padding:4px 8px; font-size:0.75rem;" title="Details"
                                    data-url="@Url.Action("Details", "Branches", new { id = item.BranchId })">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                            <button type="button" class="btn-cyber-primary btn-show-modal" style="padding:4px 8px; font-size:0.75rem; margin:0 2px; border-color:#FFB000; color:#FFB000;" title="Edit"
                                    data-url="@Url.Action("Edit", "Branches", new { id = item.BranchId })">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </button>
                            <button type="button" class="btn-cyber-danger btn-show-modal" style="padding:4px 8px; font-size:0.75rem;" title="Delete"
                                    data-url="@Url.Action("Delete", "Branches", new { id = item.BranchId })">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                    idx++;
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade modal-cyber" id="globalModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 620px;" id="globalModalContainer"></div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
