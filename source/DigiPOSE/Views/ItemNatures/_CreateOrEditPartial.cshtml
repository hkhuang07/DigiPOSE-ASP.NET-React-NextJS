@model DigiPOSE.Models.ItemNature
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-tag text-cyan me-2"></i> @(Model.NatureId == 0 ? "ADD NEW" : "EDIT") ITEMNATURE</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="@(Model.NatureId == 0 ? "Create" : "Edit")" asp-controller="ItemNatures" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="NatureId" />
        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-family:'Roboto Mono'; font-size:0.85rem;"></div>
            <div class="mb-3">
                <label asp-for="NatureName" class="form-cyber-label"></label>
                <input asp-for="NatureName" class="form-control form-cyber-control" />
                <span asp-validation-for="NatureName" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TaxXmlCode" class="form-cyber-label"></label>
                <input asp-for="TaxXmlCode" class="form-control form-cyber-control" />
                <span asp-validation-for="TaxXmlCode" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="mb-3 d-flex align-items-center gap-3">
                <label asp-for="IsActive" class="form-cyber-label mb-0"></label>
                <input asp-for="IsActive" type="checkbox" class="form-check-input" />
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-cancel" data-bs-dismiss="modal" style="border-top: 1px solid aliceblue !important; border-bottom: 1px solid aliceblue !important; border-left: none !important; border-right: none !important; color: aliceblue !important; background: #222222 !important;"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
            <button type="submit" class="btn-cyber-success"><i class="fa-solid fa-floppy-disk me-1"></i> SAVE</button>
        </div>
    </form>
</div>


