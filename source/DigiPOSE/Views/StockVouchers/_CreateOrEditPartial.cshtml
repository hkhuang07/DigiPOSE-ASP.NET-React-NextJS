@model DigiPOSE.Models.StockVoucher
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-file-invoice text-cyan me-2"></i> @(Model.VoucherId == 0 ? "NEW STOCK VOUCHER" : "EDIT VOUCHER")</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="@(Model.VoucherId == 0 ? "Create" : "Edit")" asp-controller="StockVouchers" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="VoucherId" />
        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-family:'Roboto Mono'; font-size:0.85rem;"></div>
            <div class="row g-2">
                <div class="col-md-6 mb-2">
                    <label asp-for="BranchId" class="form-cyber-label">BRANCH <span style="color:#FF3333;">*</span></label>
                    <select asp-for="BranchId" class="form-select form-cyber-control" asp-items="ViewBag.BranchId"><option value="">-- SELECT --</option></select>
                    <span asp-validation-for="BranchId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="UserId" class="form-cyber-label">EMPLOYEE <span style="color:#FF3333;">*</span></label>
                    <select asp-for="UserId" class="form-select form-cyber-control" asp-items="ViewBag.UserId"><option value="">-- SELECT --</option></select>
                    <span asp-validation-for="UserId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="SupplierId" class="form-cyber-label">SUPPLIER (optional)</label>
                    <select asp-for="SupplierId" class="form-select form-cyber-control" asp-items="ViewBag.SupplierId"><option value="">-- NONE --</option></select>
                    <span asp-validation-for="SupplierId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="VoucherType" class="form-cyber-label">VOUCHER TYPE <span style="color:#FF3333;">*</span></label>
                    <select asp-for="VoucherType" class="form-select form-cyber-control">
                        <option value="">-- SELECT --</option>
                        <option value="IN">IN - Goods Receipt</option>
                        <option value="OUT">OUT - Goods Dispatch</option>
                        <option value="ADJUST">ADJUST - Adjustment</option>
                    </select>
                    <span asp-validation-for="VoucherType" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="TotalValue" class="form-cyber-label">TOTAL VALUE (VNĐ)</label>
                    <input asp-for="TotalValue" class="form-control form-cyber-control" type="number" step="1000" />
                    <span asp-validation-for="TotalValue" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="CreatedAt" class="form-cyber-label">VOUCHER DATE</label>
                    <input asp-for="CreatedAt" class="form-control form-cyber-control" type="datetime-local" />
                    <span asp-validation-for="CreatedAt" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
            <button type="submit" class="btn-cyber-success"><i class="fa-solid fa-floppy-disk me-1"></i> SAVE VOUCHER</button>
        </div>
    </form>
</div>
