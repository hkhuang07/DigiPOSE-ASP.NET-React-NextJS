@model IEnumerable<DigiPOSE.Models.StockVoucher>
@{ ViewData["Title"] = "Stock Vouchers"; }
<div class="cyber-panel">
    <div class="cyber-panel-header">
        <div class="cyber-panel-title"><i class="fa-solid fa-file-invoice"></i> STOCK VOUCHERS</div>
        <div class="cyber-panel-sub">[WAREHOUSE MODULE] // GOODS RECEIPT / DISPATCH LEDGER</div>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <button type="button" class="btn-cyber-success btn-show-modal" data-url="@Url.Action("Create", "StockVouchers")"><i class="fa-solid fa-plus me-1"></i> NEW VOUCHER</button>
        <div style="font-family:'Roboto Mono'; font-size:0.85rem; color:#00E5FF; white-space:nowrap;">TOTAL: <strong style="color:#FFF; font-family:'VT323'; font-size:1.3rem;">@Model.Count()</strong></div>
    </div>
    <div class="table-responsive">
        <table class="table-cyber">
            <thead>
                <tr>
                    <th style="width:5%; text-align:center; white-space:nowrap;">#</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.VoucherType)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.BranchId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.UserId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.SupplierId)</th>
                    <th style="white-space:nowrap; text-align:right;">@Html.DisplayNameFor(model => model.TotalValue)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.CreatedAt)</th>
                    <th style="width:120px; text-align:center; white-space:nowrap;">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @{ int idx = 1; }
                @foreach (var item in Model) {
                    <tr>
                        <td style="font-family:'VT323'; font-size:1.2rem; color:#00E5FF; text-align:center; white-space:nowrap;">@idx.ToString("D2")</td>
                        <td style="color:#FFF; font-family:'Rajdhani'; font-weight:600; white-space:nowrap;"><span class="badge @(item.VoucherType == "IN" ? "bg-success" : "bg-warning text-dark")">@item.VoucherType</span></td>
                        <td style="color:#A0C0CE; white-space:nowrap;">@item.Branch?.BranchName</td>
                        <td style="color:#A0C0CE; white-space:nowrap;">@item.User?.UserName</td>
                        <td style="color:#A0C0CE; white-space:nowrap;">@(item.Supplier?.SupplierName ?? "---")</td>
                        <td style="color:#00FF66; font-family:'VT323'; font-size:1.1rem; text-align:right; white-space:nowrap;">@string.Format("{0:N0}", item.TotalValue)</td>
                        <td style="color:#A0C0CE; font-family:'Roboto Mono'; font-size:0.82rem; white-space:nowrap;">@item.CreatedAt.ToString("dd/MM/yy HH:mm")</td>
                        <td style="text-align:center; white-space:nowrap;">
                            <button type="button" class="btn-cyber-primary btn-show-modal" style="padding:4px 8px; font-size:0.75rem;" title="Details" data-url="@Url.Action("Details", "StockVouchers", new { id = item.VoucherId })"><i class="fa-solid fa-eye"></i></button>
                            <button type="button" class="btn-cyber-primary btn-show-modal" style="padding:4px 8px; font-size:0.75rem; margin:0 2px; border-color:#FFB000; color:#FFB000;" title="Edit" data-url="@Url.Action("Edit", "StockVouchers", new { id = item.VoucherId })"><i class="fa-solid fa-pen-to-square"></i></button>
                            <button type="button" class="btn-cyber-danger btn-show-modal" style="padding:4px 8px; font-size:0.75rem;" title="Delete" data-url="@Url.Action("Delete", "StockVouchers", new { id = item.VoucherId })"><i class="fa-solid fa-trash"></i></button>
                        </td>
                    </tr>
                    idx++;
                }
            </tbody>
        </table>
    </div>
</div>
<div class="modal fade modal-cyber" id="globalModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" style="max-width:720px;" id="globalModalContainer"></div>
</div>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
