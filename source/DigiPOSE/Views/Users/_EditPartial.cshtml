@model DigiPOSE.Models.User
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-user-pen text-cyan me-2"></i> EDIT USER</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="Edit" asp-controller="Users" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UserId" />
        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-family:'Roboto Mono'; font-size:0.85rem;"></div>
            <div class="row g-3">
                <div class="col-md-6 mb-2">
                    <label asp-for="RoleId" class="form-cyber-label">ROLE <span style="color:#FF3333;">*</span></label>
                    <select asp-for="RoleId" class="form-select form-cyber-control" asp-items="ViewBag.RoleId">
                        <option value="">-- SELECT ROLE --</option>
                    </select>
                    <span asp-validation-for="RoleId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="BranchId" class="form-cyber-label">BRANCH <span style="color:#FF3333;">*</span></label>
                    <select asp-for="BranchId" class="form-select form-cyber-control" asp-items="ViewBag.BranchId">
                        <option value="">-- SELECT BRANCH --</option>
                    </select>
                    <span asp-validation-for="BranchId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="UserName" class="form-cyber-label">USERNAME <span style="color:#FF3333;">*</span></label>
                    <input asp-for="UserName" class="form-control form-cyber-control" />
                    <span asp-validation-for="UserName" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label for="NewPassword" class="form-cyber-label">NEW PASSWORD <span style="color:#A0C0CE; font-size:0.75rem;">(leave blank to keep current)</span></label>
                    <input type="password" id="NewPassword" name="NewPassword" class="form-control form-cyber-control" placeholder="Enter new password or leave blank" />
                </div>
                <div class="col-12 mb-2">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="IsActive" />
                        <label class="form-check-label form-cyber-label" asp-for="IsActive">ACTIVE</label>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
            <button type="submit" class="btn-cyber-success"><i class="fa-solid fa-floppy-disk me-1"></i> UPDATE USER</button>
        </div>
    </form>
</div>
