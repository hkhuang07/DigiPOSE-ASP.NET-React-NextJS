@model DigiPOSE.Models.User
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-user-plus text-cyan me-2"></i> ADD NEW USER</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="Create" asp-controller="Users" method="post">
        @Html.AntiForgeryToken()
        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-family:'Roboto Mono'; font-size:0.85rem;"></div>
            <div class="row g-3">
                <div class="col-md-6 mb-2">
                    <label asp-for="RoleId" class="form-cyber-label">@Html.DisplayNameFor(model => model.RoleId) <span style="color:#FF3333;">*</span></label>
                    <select asp-for="RoleId" class="form-select form-cyber-control" asp-items="ViewBag.RoleId">
                        <option value="">-- SELECT ROLE --</option>
                    </select>
                    <span asp-validation-for="RoleId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="BranchId" class="form-cyber-label">@Html.DisplayNameFor(model => model.BranchId) <span style="color:#FF3333;">*</span></label>
                    <select asp-for="BranchId" class="form-select form-cyber-control" asp-items="ViewBag.BranchId">
                        <option value="">-- SELECT BRANCH --</option>
                    </select>
                    <span asp-validation-for="BranchId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="UserName" class="form-cyber-label">@Html.DisplayNameFor(model => model.UserName) <span style="color:#FF3333;">*</span></label>
                    <input asp-for="UserName" class="form-control form-cyber-control" placeholder="Login username" />
                    <span asp-validation-for="UserName" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="PasswordHash" class="form-cyber-label">@Html.DisplayNameFor(model => model.PasswordHash) <span style="color:#FF3333;">*</span></label>
                    <input asp-for="PasswordHash" type="password" class="form-control form-cyber-control" placeholder="Enter password" />
                    <span asp-validation-for="PasswordHash" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="FullName" class="form-cyber-label"></label>
                    <input asp-for="FullName" class="form-control form-cyber-control" placeholder="Employee full name" />
                    <span asp-validation-for="FullName" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="Email" class="form-cyber-label"></label>
                    <input asp-for="Email" type="email" class="form-control form-cyber-control" placeholder="User email address" />
                    <span asp-validation-for="Email" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="PhoneNumber" class="form-cyber-label"></label>
                    <input asp-for="PhoneNumber" class="form-control form-cyber-control" placeholder="Phone number" />
                    <span asp-validation-for="PhoneNumber" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-12 mb-2">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="IsActive" />
                        <label class="form-check-label form-cyber-label" asp-for="IsActive">ACTIVE</label>
                    </div>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
            <button type="submit" class="btn-cyber-success"><i class="fa-solid fa-floppy-disk me-1"></i> CREATE USER</button>
        </div>
    </form>
</div>

