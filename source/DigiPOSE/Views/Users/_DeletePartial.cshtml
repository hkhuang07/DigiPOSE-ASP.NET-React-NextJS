@model DigiPOSE.Models.User
<div class="modal-content" style="border-color:rgba(255,51,51,0.6);">
    <div class="modal-header" style="border-bottom-color:rgba(255,51,51,0.4);">
        <h5 class="modal-title" style="color:#FF3333;"><i class="fa-solid fa-triangle-exclamation me-2"></i> CONFIRM REMOVAL</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal" style="border-color:rgba(255,51,51,0.4);color:#FF3333;"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
        <div style="background:rgba(255,51,51,0.08);border:1px solid rgba(255,51,51,0.4);padding:1rem;margin-bottom:1rem;">
            <div style="font-family:'Orbitron';font-size:0.85rem;color:#FF3333;font-weight:bold;margin-bottom:0.5rem;">
                <i class="fa-solid fa-radiation me-2"></i> TARGET: <strong style="color:#FFF;">@Model.UserName</strong>
            </div>
            <p style="font-family:'Rajdhani';font-size:0.95rem;color:#A0C0CE;margin:0;">
                Choose action type. Hard delete is <strong style="color:#FF3333;">irreversible</strong>.
            </p>
        </div>
    </div>
    <div class="modal-footer" style="gap:8px;">
        <button type="button" class="btn-cyber-cancel" data-bs-dismiss="modal" style="border-top: 1px solid aliceblue !important; border-bottom: 1px solid aliceblue !important; border-left: none !important; border-right: none !important; color: aliceblue !important; background: #222222 !important;"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
        <form class="ajax-modal-form d-inline" asp-action="ToggleActive" asp-controller="Users" asp-route-id="@Model.UserId" method="post">
            @Html.AntiForgeryToken()
            @if (Model.IsActive)
            {
                <button type="submit" class="btn-cyber-warning" style="border-top: 1px solid #FFB000 !important; border-bottom: 1px solid #FFB000 !important; border-left: none !important; border-right: none !important; color: #FFB000 !important; background: #331a00 !important;">
                    <i class="fa-solid fa-toggle-off me-1"></i> DEACTIVATE
                </button>
            }
            else
            {
                <button type="submit" class="btn-cyber-success" style="border-top: 1px solid #00FF66 !important; border-bottom: 1px solid #00FF66 !important; border-left: none !important; border-right: none !important; color: #00FF66 !important; background: #0A0A0A !important;">
                    <i class="fa-solid fa-toggle-on me-1"></i> ACTIVATE
                </button>
            }
        </form>
        <form class="ajax-modal-form d-inline" asp-action="Delete" asp-controller="Users" asp-route-id="@Model.UserId" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-cyber-danger">
                <i class="fa-solid fa-trash me-1"></i> HARD DELETE
            </button>
        </form>
    </div>
</div>


