@model DigiPOSE.Models.ProductInventory
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-warehouse text-cyan me-2"></i> @(Model.InventoryId == 0 ? "ADD INVENTORY RECORD" : "EDIT INVENTORY")</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="@(Model.InventoryId == 0 ? "Create" : "Edit")" asp-controller="ProductInventories" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="InventoryId" />
        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-family:'Roboto Mono'; font-size:0.85rem;"></div>
            <div class="mb-3">
                <label asp-for="BranchId" class="form-cyber-label">BRANCH <span style="color:#FF3333;">*</span></label>
                <select asp-for="BranchId" class="form-select form-cyber-control" asp-items="ViewBag.BranchId"><option value="">-- SELECT BRANCH --</option></select>
                <span asp-validation-for="BranchId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ProductId" class="form-cyber-label">PRODUCT <span style="color:#FF3333;">*</span></label>
                <select asp-for="ProductId" class="form-select form-cyber-control" asp-items="ViewBag.ProductId"><option value="">-- SELECT PRODUCT --</option></select>
                <span asp-validation-for="ProductId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="row g-2">
                <div class="col-md-6 mb-2">
                    <label asp-for="StockQuantity" class="form-cyber-label">STOCK QUANTITY</label>
                    <input asp-for="StockQuantity" class="form-control form-cyber-control" type="number" min="0" />
                    <span asp-validation-for="StockQuantity" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="MinStockLevel" class="form-cyber-label">MIN STOCK LEVEL</label>
                    <input asp-for="MinStockLevel" class="form-control form-cyber-control" type="number" min="0" />
                    <span asp-validation-for="MinStockLevel" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
            <button type="submit" class="btn-cyber-success"><i class="fa-solid fa-floppy-disk me-1"></i> SAVE</button>
        </div>
    </form>
</div>
