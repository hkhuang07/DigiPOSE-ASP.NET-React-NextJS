@model IEnumerable<DigiPOSE.Models.ProductInventory>
@{ ViewData["Title"] = "Product Inventory"; }
<div class="cyber-panel">
    <div class="cyber-panel-header">
        <div class="cyber-panel-title"><i class="fa-solid fa-warehouse"></i> PRODUCT INVENTORY</div>
        <div class="cyber-panel-sub">[WAREHOUSE MODULE] // STOCK LEVELS BY BRANCH</div>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <button type="button" class="btn-cyber-success btn-show-modal" data-url="@Url.Action("Create", "ProductInventories")"><i class="fa-solid fa-plus me-1"></i> ADD INVENTORY</button>
        <div style="font-family:'Roboto Mono'; font-size:0.85rem; color:#00E5FF; white-space:nowrap;">TOTAL RECORDS: <strong id="totalRecordsCount" style="color:#FFF; font-family:'VT323'; font-size:1.3rem;">--</strong></div>
    </div>
    <div class="table-responsive">
        <table id="datatable" class="table-cyber w-100">
            <thead>
                <tr>
                    <th style="width:5%; text-align:center; white-space:nowrap;">#</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.ProductId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.BranchId)</th>
                    <th style="white-space:nowrap; text-align:right;">@Html.DisplayNameFor(model => model.StockQuantity)</th>
                    <th style="white-space:nowrap; text-align:right;">@Html.DisplayNameFor(model => model.MinStockLevel)</th>
                    <th style="white-space:nowrap; text-align:center;">STATUS</th>
                    <th style="width:120px; text-align:center; white-space:nowrap;">ACTIONS</th>
                </tr>
            </thead>
        </table>
    </div>
</div>
<div class="modal fade modal-cyber" id="globalModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" style="max-width:620px;" id="globalModalContainer"></div>
</div>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/lib/datatables/js/jquery.dataTables.min.js"></script>
    <script src="~/lib/datatables/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function(){
            var table = $('#datatable').DataTable({
                serverSide: true,
                processing: true,
                filter: true,
                ajax: {
                    url: '@Url.Action("Index_LoadData", "ProductInventories")',
                    type: "POST",
                    dataType: "JSON"
                },
                columns: [
                    { data: null, name: null, sortable: false, render: (d, t, r, meta) => meta.row + meta.settings._iDisplayStart + 1 },
                    { data: 'productName', name: 'Product.ProductName', render: d => `<span style="font-family:'Rajdhani'; font-weight:600; color:#FFF;"><i class="fa-solid fa-box me-2 text-cyan"></i>${d}</span>` },
                    { data: 'branchName', name: 'Branch.BranchName', render: d => `<span style="color:#A0C0CE;">${d}</span>` },
                    { 
                        data: 'stockQuantity', 
                        name: 'StockQuantity', 
                        render: (d, t, r) => {
                            var lowStock = d <= r.minStockLevel;
                            var color = lowStock ? "#FF3333" : "#00FF66";
                            return `<span style="color:${color}; font-family:'VT323'; font-size:1.2rem; display:block; text-align:right;">${d}</span>`;
                        }
                    },
                    { data: 'minStockLevel', name: 'MinStockLevel', render: d => `<span style="color:#FFB000; font-family:'VT323'; font-size:1.2rem; display:block; text-align:right;">${d}</span>` },
                    { 
                        data: null, 
                        searchable: false, 
                        orderable: false, 
                        render: (d, t, r) => {
                            var lowStock = r.stockQuantity <= r.minStockLevel;
                            if (lowStock) {
                                return `<div style="text-align:center;"><span class="badge bg-danger">LOW STOCK</span></div>`;
                            } else {
                                return `<div style="text-align:center;"><span class="badge bg-success">OK</span></div>`;
                            }
                        }
                    },
                    { 
                        data: null, 
                        searchable: false, 
                        orderable: false, 
                        render: function (d, t, r) { 
                            var detailsUrl = '@Url.Action("Details", "ProductInventories")/' + r.inventoryId;
                            var editUrl = '@Url.Action("Edit", "ProductInventories")/' + r.inventoryId;
                            var deleteUrl = '@Url.Action("Delete", "ProductInventories")/' + r.inventoryId;
                            return '<div style="text-align:center;">'
                                 + '<button type="button" class="btn-cyber-primary btn-show-modal" data-url="' + detailsUrl + '" style="padding:4px 8px; font-size:0.75rem;"><i class="fa-solid fa-eye"></i></button> '
                                 + '<button type="button" class="btn-cyber-primary btn-show-modal" data-url="' + editUrl + '" style="padding:4px 8px; font-size:0.75rem; border-color:#FFB000; color:#FFB000;"><i class="fa-solid fa-pen-to-square"></i></button> ' 
                                 + '<button type="button" class="btn-cyber-danger btn-show-modal" data-url="' + deleteUrl + '" style="padding:4px 8px; font-size:0.75rem;"><i class="fa-solid fa-trash"></i></button>'
                                 + '</div>'; 
                        } 
                    }                        
                ],
                drawCallback: function (settings) {
                    var api = this.api();
                    var json = api.ajax.json();
                    if (json && json.recordsTotal !== undefined) {
                        $('#totalRecordsCount').text(json.recordsTotal);
                    }
                }
            });   
        });
    </script>
}
