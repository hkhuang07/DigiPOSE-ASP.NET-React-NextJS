@model DigiPOSE.Models.Customer
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-user-group text-cyan me-2"></i> @(Model.CustomerId == 0 ? "ADD NEW" : "EDIT") CUSTOMER</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="@(Model.CustomerId == 0 ? "Create" : "Edit")" asp-controller="Customers" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="CustomerId" />
        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-family:'Roboto Mono'; font-size:0.85rem;"></div>
            
            @* SECTION 1: GENERAL & CONTACT INFO *@
            <div style="border-bottom: 1px dashed rgba(0,229,255,0.3); padding-bottom: 8px; margin-bottom: 12px;">
                <span style="font-family:'Orbitron'; font-size:0.8rem; color:#00E5FF; text-transform:uppercase; letter-spacing:1px;">
                    <i class="fa-solid fa-user me-1"></i> 1. PERSONAL / CONTACT INFO
                </span>
            </div>
            <div class="row g-2 mb-3">
                <div class="col-md-6 mb-2">
                    <label asp-for="CustomeTypeId" class="form-cyber-label">CUSTOMER TYPE</label>
                    <select asp-for="CustomeTypeId" class="form-select form-cyber-control" asp-items="ViewBag.CustomeTypeId">
                        <option value="">-- SELECT TYPE --</option>
                    </select>
                    <span asp-validation-for="CustomeTypeId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="FullName" class="form-cyber-label">FULL NAME / REPRESENTATIVE <span style="color:#FF3333;">*</span></label>
                    <input asp-for="FullName" class="form-control form-cyber-control" placeholder="Customer or Representative Name" />
                    <span asp-validation-for="FullName" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-4 mb-2">
                    <label asp-for="PhoneNumber" class="form-cyber-label">PHONE NUMBER</label>
                    <input asp-for="PhoneNumber" class="form-control form-cyber-control" placeholder="0xxx-xxx-xxx" />
                    <span asp-validation-for="PhoneNumber" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-4 mb-2">
                    <label asp-for="Email" class="form-cyber-label">EMAIL</label>
                    <input asp-for="Email" class="form-control form-cyber-control" placeholder="customer@email.com" />
                    <span asp-validation-for="Email" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-4 mb-2">
                    <label asp-for="IdNo" class="form-cyber-label">ID NUMBER</label>
                    <input asp-for="IdNo" class="form-control form-cyber-control" placeholder="ID / Passport No" />
                    <span asp-validation-for="IdNo" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
            </div>

            @* SECTION 2: ENTERPRISE & E-INVOICE TAX DETAILS *@
            <div style="border-bottom: 1px dashed rgba(0,229,255,0.3); padding-bottom: 8px; margin-bottom: 12px; margin-top: 16px;">
                <span style="font-family:'Orbitron'; font-size:0.8rem; color:#00FF66; text-transform:uppercase; letter-spacing:1px;">
                    <i class="fa-solid fa-building me-1"></i> 2. ENTERPRISE DETAILS
                </span>
            </div>
            <div class="row g-2 p-2" style="background: rgba(0,229,255,0.02); border: 1px solid rgba(0,229,255,0.15); border-radius: 4px;">
                <div class="col-md-6 mb-2">
                    <label asp-for="CompanyName" class="form-cyber-label">COMPANY / ENTERPRISE NAME</label>
                    <input asp-for="CompanyName" class="form-control form-cyber-control" placeholder="Full legal company name" />
                    <span asp-validation-for="CompanyName" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-3 mb-2">
                    <label asp-for="TaxCode" class="form-cyber-label">TAX CODE</label>
                    <input asp-for="TaxCode" class="form-control form-cyber-control" placeholder="Tax ID Number" />
                    <span asp-validation-for="TaxCode" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-3 mb-2">
                    <label asp-for="BudgetCode" class="form-cyber-label">BUDGET CODE</label>
                    <input asp-for="BudgetCode" class="form-control form-cyber-control" placeholder="Budget Unit Code" />
                    <span asp-validation-for="BudgetCode" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="BankName" class="form-cyber-label">BANK NAME</label>
                    <input asp-for="BankName" class="form-control form-cyber-control" placeholder="Bank Name" />
                    <span asp-validation-for="BankName" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="BankAccount" class="form-cyber-label">BANK ACCOUNT NUMBER</label>
                    <input asp-for="BankAccount" class="form-control form-cyber-control" placeholder="Account Number" />
                    <span asp-validation-for="BankAccount" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-12 mb-2">
                    <label asp-for="Address" class="form-cyber-label">BILLING / INVOICE ADDRESS</label>
                    <input asp-for="Address" class="form-control form-cyber-control" placeholder="Official registered tax address" />
                    <span asp-validation-for="Address" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="DebtBalance" class="form-cyber-label">DEBT BALANCE</label>
                    <input asp-for="DebtBalance" class="form-control form-cyber-control" type="number" step="any" placeholder="0.00" />
                    <span asp-validation-for="DebtBalance" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="Notes" class="form-cyber-label">NOTES / REMARKS</label>
                    <textarea asp-for="Notes" class="form-control form-cyber-control" rows="2" placeholder="Customer notes"></textarea>
                    <span asp-validation-for="Notes" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
            </div>

            <div class="mt-3 d-flex align-items-center gap-3">
                <label asp-for="IsActive" class="form-cyber-label mb-0">ACTIVE</label>
                <input asp-for="IsActive" type="checkbox" class="form-check-input form-check-cyber" />
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-cancel" data-bs-dismiss="modal" style="border-top: 1px solid aliceblue !important; border-bottom: 1px solid aliceblue !important; border-left: none !important; border-right: none !important; color: aliceblue !important; background: #222222 !important;"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
            <button type="submit" class="btn-cyber-success"><i class="fa-solid fa-floppy-disk me-1"></i> SAVE CUSTOMER</button>
        </div>
    </form>
</div>



