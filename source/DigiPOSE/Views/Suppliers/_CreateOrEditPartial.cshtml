@model DigiPOSE.Models.Supplier
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-truck-fast text-cyan me-2"></i> @(Model.SupplierId == 0 ? "ADD NEW" : "EDIT") SUPPLIER</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="@(Model.SupplierId == 0 ? "Create" : "Edit")" asp-controller="Suppliers" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="SupplierId" />
        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-family:'Roboto Mono'; font-size:0.85rem;"></div>
            <div class="mb-3">
                <label asp-for="SupplierName" class="form-cyber-label">@Html.DisplayNameFor(model => model.SupplierName) <span style="color:#FF3333;">*</span></label>
                <input asp-for="SupplierName" class="form-control form-cyber-control" placeholder="Enter supplier company name" />
                <span asp-validation-for="SupplierName" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="ContactPerson" class="form-cyber-label"></label>
                    <input asp-for="ContactPerson" class="form-control form-cyber-control" placeholder="Contact person name" />
                    <span asp-validation-for="ContactPerson" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Phone" class="form-cyber-label"></label>
                    <input asp-for="Phone" class="form-control form-cyber-control" placeholder="Contact phone number" />
                    <span asp-validation-for="Phone" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-cyber-label"></label>
                    <input asp-for="Email" type="email" class="form-control form-cyber-control" placeholder="Supplier email" />
                    <span asp-validation-for="Email" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="TaxCode" class="form-cyber-label"></label>
                    <input asp-for="TaxCode" class="form-control form-cyber-control" placeholder="Tax identification number" />
                    <span asp-validation-for="TaxCode" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Address" class="form-cyber-label"></label>
                <input asp-for="Address" class="form-control form-cyber-control" placeholder="Supplier address" />
                <span asp-validation-for="Address" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="BankName" class="form-cyber-label"></label>
                    <input asp-for="BankName" class="form-control form-cyber-control" placeholder="Bank name" />
                    <span asp-validation-for="BankName" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="BankAccount" class="form-cyber-label"></label>
                    <input asp-for="BankAccount" class="form-control form-cyber-control" placeholder="Account number" />
                    <span asp-validation-for="BankAccount" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Website" class="form-cyber-label"></label>
                    <input asp-for="Website" class="form-control form-cyber-control" placeholder="https://supplier.com" />
                    <span asp-validation-for="Website" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="DebtBalance" class="form-cyber-label"></label>
                    <input asp-for="DebtBalance" class="form-control form-cyber-control" type="number" step="any" placeholder="0.00" />
                    <span asp-validation-for="DebtBalance" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-cyber-label"></label>
                <textarea asp-for="Description" class="form-control form-cyber-control" rows="2" placeholder="Supplier notes or details"></textarea>
                <span asp-validation-for="Description" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="mb-3 d-flex align-items-center gap-3">
                <label asp-for="IsActive" class="form-cyber-label mb-0"></label>
                <input asp-for="IsActive" type="checkbox" class="form-check-input form-check-cyber" />
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
            <button type="submit" class="btn-cyber-success"><i class="fa-solid fa-floppy-disk me-1"></i> SAVE</button>
        </div>
    </form>
</div>
