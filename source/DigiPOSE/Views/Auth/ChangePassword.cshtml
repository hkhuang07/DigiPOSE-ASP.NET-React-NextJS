@model DigiPOSE.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "UPDATE CREDENTIALS";
    Layout = "~/Areas/Administrator/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="terminal-box" style="width: 500px; padding: 2px; background: rgba(0, 0, 0, 0.8); border: 2px solid #00FF66; box-shadow: inset 0 0 10px #00FF66, 0 0 15px rgba(0,255,102,0.4); position: relative;">
        <div class="terminal-header" style="background-color: #00FF66; color: #000; font-weight: bold; padding: 5px 10px; display: flex; justify-content: space-between; align-items: center; font-size: 0.9rem; letter-spacing: 2px; font-family: 'Courier New', Courier, monospace;">
            <span>> UPDATE SECURITY KEY _</span>
            <span><i class="fa-solid fa-xmark"></i></span>
        </div>
        <div class="terminal-content" style="padding: 30px; border: 1px solid #00FF66; margin: 2px; font-family: 'Courier New', Courier, monospace;">
            <div class="text-center mb-4">
                <i class="fa-solid fa-key mb-3" style="font-size: 3rem; color: #00FF66;"></i>
                <h4 style="margin: 0; font-weight: bold; letter-spacing: 4px; color: #00FF66;">CREDENTIALS</h4>
            </div>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger" style="background: rgba(255, 51, 51, 0.1); border: 1px solid #FF3333; color: #FF3333; font-size: 0.85rem; border-radius: 0;" role="alert">
                    > WARNING: @TempData["ErrorMessage"]
                </div>
            }

            <form asp-area="" asp-controller="Auth" asp-action="ChangePassword" method="post">
                <div class="mb-4">
                    <label asp-for="CurrentPassword" class="form-label" style="font-size: 0.9rem; text-transform: uppercase; letter-spacing: 2px; color: #00FF66;">CURRENT KEY:</label>
                    <input asp-for="CurrentPassword" class="form-control" style="background: transparent; border: none; border-bottom: 2px solid #00FF66; color: #FFF; border-radius: 0; box-shadow: none; font-family: 'Courier New', Courier, monospace; padding: 5px 0; font-size: 1.1rem; width: 100%;" />
                    <span asp-validation-for="CurrentPassword" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="NewPassword" class="form-label" style="font-size: 0.9rem; text-transform: uppercase; letter-spacing: 2px; color: #00FF66;">NEW KEY:</label>
                    <input asp-for="NewPassword" class="form-control" style="background: transparent; border: none; border-bottom: 2px solid #00FF66; color: #FFF; border-radius: 0; box-shadow: none; font-family: 'Courier New', Courier, monospace; padding: 5px 0; font-size: 1.1rem; width: 100%;" />
                    <span asp-validation-for="NewPassword" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <div class="mb-5">
                    <label asp-for="ConfirmNewPassword" class="form-label" style="font-size: 0.9rem; text-transform: uppercase; letter-spacing: 2px; color: #00FF66;">CONFIRM KEY:</label>
                    <input asp-for="ConfirmNewPassword" class="form-control" style="background: transparent; border: none; border-bottom: 2px solid #00FF66; color: #FFF; border-radius: 0; box-shadow: none; font-family: 'Courier New', Courier, monospace; padding: 5px 0; font-size: 1.1rem; width: 100%;" />
                    <span asp-validation-for="ConfirmNewPassword" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" asp-controller="Home" class="btn text-center" style="background: transparent; color: #FF3333; border: 1px solid #FF3333; font-family: 'Courier New', Courier, monospace; font-weight: bold; letter-spacing: 2px; padding: 10px 20px; text-transform: uppercase; transition: all 0.2s; width: 45%; text-decoration: none;">
                        [ CANCEL ]
                    </a>
                    <button type="submit" class="btn" style="background: transparent; color: #00FF66; border: 1px solid #00FF66; font-family: 'Courier New', Courier, monospace; font-weight: bold; letter-spacing: 2px; padding: 10px 20px; text-transform: uppercase; transition: all 0.2s; width: 45%;">
                        [ UPDATE ]
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
