@model DigiPOSE.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "SYSTEM LOGIN - DIGIPOSE";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css" />
    <link rel="stylesheet" href="~/css/cyber-hud.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/cyber-auth.css" asp-append-version="true" />
</head>
<body class="auth-page auth-login-bg">

    <div class="auth-wrapper">
        <div class="auth-card">
            <!-- Left Image Panel -->
            <div class="auth-panel-left login-panel-bg">
                <div class="auth-panel-left-overlay"></div>
                <div class="auth-panel-left-content">
                    <svg class="auth-brand-logo" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <polygon points="50,5 95,27 95,73 50,95 5,73 5,27" stroke="#00E5FF" stroke-width="4" fill="rgba(0, 229, 255, 0.1)"/>
                        <circle cx="50" cy="50" r="24" stroke="#00E5FF" stroke-width="3" stroke-dasharray="6 4"/>
                        <circle cx="50" cy="50" r="8" fill="#00E5FF"/>
                        <line x1="50" y1="15" x2="50" y2="35" stroke="#00E5FF" stroke-width="3"/>
                        <line x1="50" y1="65" x2="50" y2="85" stroke="#00E5FF" stroke-width="3"/>
                    </svg>
                    <div class="auth-brand-title">Digi<span>POSE</span></div>
                    <div class="auth-brand-slogan">
                        MULTI-PROVIDER INTEGRATION STATION<br/>
                        <span style="color:#00E5FF; font-size:0.75rem;">MY CONFIDENCE, YOUR CONVENIENCE</span>
                    </div>
                </div>
            </div>

            <!-- Right Form Panel - Gradient Left (Transparent) -> Right (#000624) -->
            <div class="auth-panel-right">
                <div>
                    <div class="auth-header-row">
                        <a href="@Url.Content("~/")" class="btn-back-home" tabindex="6">
                            <i class="fa-solid fa-arrow-left"></i> BACK
                        </a>
                        <div class="node-tag">
                            <i class="fa-solid fa-shield-halved me-1"></i> SECURE NODE
                        </div>
                    </div>

                    <h3 class="auth-form-title">LOGIN</h3>
                    <div class="auth-form-sub">> SYSTEM ACCESS PROTOCOL</div>

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger" style="background: rgba(255, 51, 51, 0.15); border: 1px solid #FF3333; color: #FF3333; font-family: 'Roboto Mono', monospace; font-size: 0.85rem; border-radius: 0;" role="alert">
                            <i class="fa-solid fa-triangle-exclamation me-1"></i> @TempData["ErrorMessage"]
                        </div>
                    }
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success" style="background: rgba(0, 229, 255, 0.15); border: 1px solid #00E5FF; color: #00E5FF; font-family: 'Roboto Mono', monospace; font-size: 0.85rem; border-radius: 0;" role="alert">
                            <i class="fa-solid fa-circle-check me-1"></i> @TempData["SuccessMessage"]
                        </div>
                    }

                    <form id="loginForm" asp-area="" asp-controller="Auth" asp-action="Login" method="post">
                        <input type="hidden" asp-for="ReturnUrl" value="@ViewBag.ReturnUrl" />

                        <div class="form-cyber-group">
                            <label asp-for="Username">USERNAME</label>
                            <div class="input-icon-wrapper">
                                <i class="fa-solid fa-user"></i>
                                <input asp-for="Username" class="form-cyber-input" autocomplete="off" placeholder="operator@digipose.vn" tabindex="1" autofocus />
                            </div>
                            <span asp-validation-for="Username" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.75rem;"></span>
                        </div>

                        <div class="form-cyber-group mb-3">
                            <label asp-for="Password">PASSWORD</label>
                            <div class="input-icon-wrapper">
                                <i class="fa-solid fa-lock"></i>
                                <input asp-for="Password" type="password" class="form-cyber-input" placeholder="••••••••••••" tabindex="2" />
                            </div>
                            <span asp-validation-for="Password" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.75rem;"></span>
                        </div>

                        <div class="auth-options-row">
                            <label class="cyber-checkbox-label">
                                <input type="checkbox" class="cyber-checkbox" id="rememberMe" name="RememberMe" value="true" />
                                <span>Remember choice</span>
                            </label>
                            <a asp-action="ForgotPassword" class="link-forgot" tabindex="5">Forgot password?</a>
                        </div>

                        <div class="auth-btn-row">
                            <a href="@Url.Content("~/")" class="btn btn-cyber-cancel" tabindex="4">
                                <i class="fa-solid fa-xmark"></i> CANCEL
                            </a>
                            <button type="submit" class="btn btn-cyber-submit" id="loginSubmitBtn" tabindex="3">
                                <i class="fa-solid fa-power-off"></i> LOGIN
                            </button>
                        </div>
                    </form>
                </div>

                <div class="link-signup-row">
                    Do not have an account yet? <a asp-action="Register" tabindex="5">Sign Up</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Cinematic Auth Progress Bar Simulation Overlay -->
    <div id="authProgressOverlay">
        <div class="cyber-proc-box" style="width: 460px; max-width: 90%; background: #000000; border-top: 2px solid #00E5FF; border-bottom: 2px solid #00E5FF; clip-path: polygon(14px 0, 100% 0, calc(100% - 14px) 100%, 0 100%); box-shadow: 0 0 35px rgba(0, 229, 255, 0.5);">
            <div class="cyber-proc-header" style="background:#00E5FF; color:#000000;">AUTHENTICATING...</div>
            <div class="cyber-proc-content" style="padding: 24px;">
                <div class="cyber-proc-status-row">
                    <span class="cyber-proc-status-title" style="color:#00E5FF;">STATUS:</span>
                    <span class="cyber-proc-status-pct" id="authPctVal" style="color:#00FF66;">15%</span>
                </div>
                <div class="cyber-proc-bar-frame" style="border:1px solid #00E5FF;">
                    <div class="cyber-proc-bar-fill" id="authBarFill" style="width: 15%;"></div>
                </div>
                <div class="cyber-proc-logs" style="color:#00FF66;">
                    <div id="authLogLine">> AUTHENTICATING ACCESS PROTOCOL...</div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Textfield Filled State Manager (Default: Aliceblue | Filled: Cyan Blue #00E5FF)
            function updateInputFilledState(input) {
                const wrapper = input.closest('.input-icon-wrapper') || input.parentElement;
                if (input.value.trim().length > 0) {
                    input.classList.add('is-filled');
                    if (wrapper) wrapper.classList.add('is-filled');
                } else {
                    input.classList.remove('is-filled');
                    if (wrapper) wrapper.classList.remove('is-filled');
                }
            }

            document.querySelectorAll('.form-cyber-input').forEach(input => {
                updateInputFilledState(input);
                input.addEventListener('input', function() { updateInputFilledState(this); });
                input.addEventListener('blur', function() { updateInputFilledState(this); });
            });

            // Auth Submission Progress Bar Simulation
            const loginForm = document.getElementById("loginForm");
            const overlay = document.getElementById("authProgressOverlay");
            const pctVal = document.getElementById("authPctVal");
            const barFill = document.getElementById("authBarFill");
            const logLine = document.getElementById("authLogLine");

            if (loginForm) {
                loginForm.addEventListener("submit", function (e) {
                    const username = document.getElementById("Username") ? document.getElementById("Username").value : "";
                    const password = document.getElementById("Password") ? document.getElementById("Password").value : "";

                    if (!username || !password) return; // Allow client validation to run

                    e.preventDefault();
                    overlay.style.display = "flex";

                    const logs = [
                        "> AUTHENTICATING ACCESS PROTOCOL...",
                        "> VERIFYING CREDENTIALS...",
                        "> SEARCHING DATA CLUSTER...",
                        "> FOUND USER MATCH: " + username.toUpperCase(),
                        "> SELECTING USER ROLE PROTOCOL...",
                        "> CHECKING ROLE PERMISSIONS...",
                        "> ACCESS GRANTED - REDIRECTING..."
                    ];

                    let currentPct = 15;
                    let logIdx = 0;

                    const interval = setInterval(function () {
                        currentPct += Math.floor(Math.random() * 20) + 15;
                        if (currentPct > 98) currentPct = 98;

                        pctVal.textContent = currentPct + "%";
                        barFill.style.width = currentPct + "%";

                        if (logIdx < logs.length) {
                            logLine.textContent = logs[logIdx];
                            logIdx++;
                        }

                        if (currentPct >= 98 && logIdx >= logs.length) {
                            clearInterval(interval);
                            setTimeout(function () {
                                loginForm.submit();
                            }, 250);
                        }
                    }, 120);
                });
            }
        });
    </script>
</body>
</html>
