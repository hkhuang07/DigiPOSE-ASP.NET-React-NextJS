@model DigiPOSE.Models.User

<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-user text-cyan me-2"></i> USER DETAILS</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal" aria-label="Close">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>
    <div class="modal-body">
        <div style="background: rgba(0, 0, 0, 0.6); border: 1px solid rgba(0, 229, 255, 0.3); padding: 1.25rem;">
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">User ID:</div>
                <div class="col-8" style="font-family:'VT323'; font-size:1.4rem; color:#FFF;">#@Model.UserId.ToString("D4")</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">Username:</div>
                <div class="col-8" style="font-family:'Rajdhani'; font-size:1.1rem; font-weight:bold; color:#FFF;">@Model.UserName</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">Full Name:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#FFF;">@(string.IsNullOrEmpty(Model.FullName) ? "N/A" : Model.FullName)</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">Email:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#A0C0CE; word-break:break-word;">@(string.IsNullOrEmpty(Model.Email) ? "N/A" : Model.Email)</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">Phone Number:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.95rem; color:#FFF;">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "N/A" : Model.PhoneNumber)</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">Role:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.95rem; color:#FFB000;">[@(Model.Role != null ? Model.Role.RoleName : "NONE")]</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">Branch:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.95rem; color:#00FF66;">@(Model.Branch != null ? Model.Branch.BranchName : "GLOBAL")</div>
            </div>
            <div class="row align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">Status:</div>
                <div class="col-8"><span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">@(Model.IsActive ? "ACTIVE" : "INACTIVE")</span></div>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn-cyber-cancel" data-bs-dismiss="modal">
            <i class="fa-solid fa-xmark me-1"></i> CLOSE
        </button>
    </div>
</div>
