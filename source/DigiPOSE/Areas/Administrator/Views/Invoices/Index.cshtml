@model IEnumerable<DigiPOSE.Models.Invoice>
@{ ViewData["Title"] = "Financial Invoices"; }
<div class="cyber-panel">
    <div class="cyber-panel-header">
        <div class="cyber-panel-title"><i class="fa-solid fa-file-signature"></i> FINANCIAL INVOICES</div>
        <div class="cyber-panel-sub">[FINANCE MODULE] // TAX INVOICE LEDGER</div>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <button type="button" class="btn-cyber-success btn-show-modal" data-url="@Url.Action("Create", "Invoices")"><i class="fa-solid fa-plus me-1"></i> NEW INVOICE</button>
        <div style="font-family:'Roboto Mono'; font-size:0.85rem; color:#00E5FF; white-space:nowrap;">TOTAL RECORDS: <strong id="totalRecordsCount" style="color:#FFF; font-family:'VT323'; font-size:1.3rem;">--</strong></div>
    </div>
    <div class="table-responsive">
        <table id="datatable" class="table-cyber w-100">
            <thead>
                <tr>
                    <th style="width:5%; text-align:center; white-space:nowrap;">#</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.InvoiceNo)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.Form)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.Series)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.InvoiceTypeId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.InvoiceStatusId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.Date)</th>
                    <th style="width:120px; text-align:center; white-space:nowrap;">ACTIONS</th>
                </tr>
            </thead>
        </table>
    </div>
</div>
<div class="modal fade modal-cyber" id="globalModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" style="max-width:720px;" id="globalModalContainer"></div>
</div>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/lib/datatables/js/jquery.dataTables.min.js"></script>
    <script src="~/lib/datatables/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function(){
            var table = $('#datatable').DataTable({
                serverSide: true,
                processing: true,
                filter: true,
                ajax: {
                    url: '@Url.Action("Index_LoadData", "Invoices")',
                    type: "POST",
                    dataType: "JSON"
                },
                order: [[6, 'desc']], // Default order by Date descending
                columns: [
                    { data: null, name: null, sortable: false, render: (d, t, r, meta) => meta.row + meta.settings._iDisplayStart + 1 },
                    { data: 'invoiceNo', name: 'InvoiceNo', render: d => `<span style="color:#FFF; font-family:'Rajdhani'; font-weight:600;"><i class="fa-solid fa-file-signature me-2 text-cyan"></i>${d}</span>` },
                    { data: 'form', name: 'Form', render: d => `<span style="color:#A0C0CE; font-family:'Roboto Mono'; font-size:0.85rem;">${d}</span>` },
                    { data: 'series', name: 'Series', render: d => `<span style="color:#A0C0CE; font-family:'Roboto Mono'; font-size:0.85rem;">${d}</span>` },
                    { data: 'typeName', name: 'InvoiceType.TypeName', render: d => `<span style="color:#A0C0CE;">${d}</span>` },
                    { data: 'statusName', name: 'InvoiceStatus.StatusName', render: d => `<span class="badge bg-info">${d}</span>` },
                    { 
                        data: 'date', 
                        name: 'Date', 
                        render: d => `<span style="color:#A0C0CE; font-family:'Roboto Mono'; font-size:0.82rem;">${d}</span>`
                    },
                    { 
                        data: null, 
                        searchable: false, 
                        orderable: false, 
                        render: function (d, t, r) { 
                            var detailsUrl = '@Url.Action("Details", "Invoices")/' + r.invoiceId;
                            var editUrl = '@Url.Action("Edit", "Invoices")/' + r.invoiceId;
                            var deleteUrl = '@Url.Action("Delete", "Invoices")/' + r.invoiceId;
                            return '<div style="text-align:center;">'
                                 + '<button type="button" class="btn-cyber-primary btn-show-modal" data-url="' + detailsUrl + '" style="padding:4px 8px; font-size:0.75rem;"><i class="fa-solid fa-eye"></i></button> '
                                 + '<button type="button" class="btn-cyber-primary btn-show-modal" data-url="' + editUrl + '" style="padding:4px 8px; font-size:0.75rem; border-color:#FFB000; color:#FFB000;"><i class="fa-solid fa-pen-to-square"></i></button> ' 
                                 + '<button type="button" class="btn-cyber-danger btn-show-modal" data-url="' + deleteUrl + '" style="padding:4px 8px; font-size:0.75rem;"><i class="fa-solid fa-trash"></i></button>'
                                 + '</div>'; 
                        } 
                    }                        
                ],
                drawCallback: function (settings) {
                    var api = this.api();
                    var json = api.ajax.json();
                    if (json && json.recordsTotal !== undefined) {
                        $('#totalRecordsCount').text(json.recordsTotal);
                    }
                }
            });   
        });
    </script>
}
