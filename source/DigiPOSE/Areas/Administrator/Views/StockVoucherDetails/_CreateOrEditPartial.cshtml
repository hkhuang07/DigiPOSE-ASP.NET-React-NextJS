@model DigiPOSE.Models.StockVoucherDetail
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-list-check text-cyan me-2"></i> @(Model.VoucherDetailId == 0 ? "ADD LINE ITEM" : "EDIT LINE ITEM")</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="@(Model.VoucherDetailId == 0 ? "Create" : "Edit")" asp-controller="StockVoucherDetails" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="VoucherDetailId" />
        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-family:'Roboto Mono'; font-size:0.85rem;"></div>
            <div class="mb-3">
                <label asp-for="VoucherId" class="form-cyber-label">@Html.DisplayNameFor(model => model.VoucherId) <span style="color:#FF3333;">*</span></label>
                <select asp-for="VoucherId" class="form-select form-cyber-control" asp-items="ViewBag.VoucherId"><option value="">-- SELECT VOUCHER --</option></select>
                <span asp-validation-for="VoucherId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ProductId" class="form-cyber-label">@Html.DisplayNameFor(model => model.ProductId) <span style="color:#FF3333;">*</span></label>
                <select asp-for="ProductId" class="form-select form-cyber-control" asp-items="ViewBag.ProductId"><option value="">-- SELECT PRODUCT --</option></select>
                <span asp-validation-for="ProductId" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="row g-2">
                <div class="col-md-6 mb-2">
                    <label asp-for="Quantity" class="form-cyber-label">@Html.DisplayNameFor(model => model.Quantity) <span style="color:#FF3333;">*</span></label>
                    <input asp-for="Quantity" class="form-control form-cyber-control" type="number" min="1" />
                    <span asp-validation-for="Quantity" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
                <div class="col-md-6 mb-2">
                    <label asp-for="ActualPrice" class="form-cyber-label"></label>
                    <input asp-for="ActualPrice" class="form-control form-cyber-control" type="number" step="any" min="0" />
                    <span asp-validation-for="ActualPrice" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-cancel" data-bs-dismiss="modal" style="border-top: 1px solid aliceblue !important; border-bottom: 1px solid aliceblue !important; border-left: none !important; border-right: none !important; color: aliceblue !important; background: #222222 !important;"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
            <button type="submit" class="btn-cyber-success"><i class="fa-solid fa-floppy-disk me-1"></i> SAVE</button>
        </div>
    </form>
</div>

