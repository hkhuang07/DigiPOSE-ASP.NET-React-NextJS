@model DigiPOSE.Models.Order
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-cart-shopping text-cyan me-2"></i> ORDER DETAILS #@Model.OrderId</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
        <table class="table-cyber" style="font-family:'Roboto Mono'; font-size:0.9rem;">
            <tr><td style="color:#00E5FF; width:40%;">ORDER ID</td><td style="font-family:'VT323'; font-size:1.2rem;">#@Model.OrderId</td></tr>
            <tr><td style="color:#00E5FF;">CUSTOMER</td><td>@(Model.SnapshotCustomerName ?? Model.Customer?.FullName ?? "Walk-in")</td></tr>
            <tr><td style="color:#00E5FF;">STATUS</td><td><span class="badge bg-info">@Model.OrderStatus?.StatusName</span></td></tr>
            <tr><td style="color:#00E5FF;">PAYMENT</td><td>@(Model.PaymentMethod?.MethodName ?? "---")</td></tr>
            <tr><td style="color:#00E5FF;">GROSS AMOUNT</td><td style="color:#A0C0CE; font-family:'VT323'; font-size:1.1rem;">@string.Format("{0:N0}", Model.GrossAmount)</td></tr>
            <tr><td style="color:#00E5FF;">DISCOUNT</td><td style="color:#FFB000; font-family:'VT323'; font-size:1.1rem;">@string.Format("{0:N0}", Model.DiscountAmount)</td></tr>
            <tr><td style="color:#00E5FF;">TAX</td><td style="color:#FFB000; font-family:'VT323'; font-size:1.1rem;">@string.Format("{0:N0}", Model.TaxAmount)</td></tr>
            <tr><td style="color:#00E5FF;">TOTAL</td><td style="color:#00FF66; font-family:'VT323'; font-size:1.3rem; font-weight:bold;">@string.Format("{0:N0}", Model.TotalAmount) VNĐ</td></tr>
            <tr><td style="color:#00E5FF;">@Html.DisplayNameFor(model => model.CreatedAt)</td><td>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td></tr>
        </table>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn-cyber-cancel" data-bs-dismiss="modal" style="border-top: 1px solid aliceblue !important; border-bottom: 1px solid aliceblue !important; border-left: none !important; border-right: none !important; color: aliceblue !important; background: #222222 !important;"><i class="fa-solid fa-xmark me-1"></i> CLOSE</button>
    </div>
</div>

