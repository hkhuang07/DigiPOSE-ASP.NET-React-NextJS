@model DigiPOSE.Models.OrderStatus
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-circle-dot text-cyan me-2"></i> @(Model.StatusId == 0 ? "ADD NEW" : "EDIT") ORDERSTATUS</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="@(Model.StatusId == 0 ? "Create" : "Edit")" asp-controller="OrderStatuses" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="StatusId" />
        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-family:'Roboto Mono'; font-size:0.85rem;"></div>
            <div class="mb-3">
                <label asp-for="StatusName" class="form-cyber-label"></label>
                <input asp-for="StatusName" class="form-control form-cyber-control" />
                <span asp-validation-for="StatusName" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="mb-3">
                <label asp-for="BadgeColor" class="form-cyber-label"></label>
                <input asp-for="BadgeColor" class="form-control form-cyber-control" />
                <span asp-validation-for="BadgeColor" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-cyber-label"></label>
                <input asp-for="Description" class="form-control form-cyber-control" />
                <span asp-validation-for="Description" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-cancel" data-bs-dismiss="modal" style="border-top: 1px solid aliceblue !important; border-bottom: 1px solid aliceblue !important; border-left: none !important; border-right: none !important; color: aliceblue !important; background: #222222 !important;"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
            <button type="submit" class="btn-cyber-success"><i class="fa-solid fa-floppy-disk me-1"></i> SAVE</button>
        </div>
    </form>
</div>

