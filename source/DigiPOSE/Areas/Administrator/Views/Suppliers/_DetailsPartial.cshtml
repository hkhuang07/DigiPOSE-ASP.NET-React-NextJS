@model DigiPOSE.Models.Supplier
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-truck-fast text-cyan me-2"></i> SUPPLIER DETAILS</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
        <table class="table-cyber" style="font-family:'Roboto Mono'; font-size:0.9rem;">
            <tr><td style="color:#00E5FF; width:35%;">@Html.DisplayNameFor(model => model.SupplierId)</td><td>@Model.SupplierId</td></tr>
            <tr><td style="color:#00E5FF;">@Html.DisplayNameFor(model => model.SupplierName)</td><td style="font-weight:600;">@Model.SupplierName</td></tr>
            <tr><td style="color:#00E5FF;">CONTACT PERSON</td><td>@(string.IsNullOrEmpty(Model.ContactPerson) ? "N/A" : Model.ContactPerson)</td></tr>
            <tr><td style="color:#00E5FF;">PHONE</td><td>@(string.IsNullOrEmpty(Model.Phone) ? "N/A" : Model.Phone)</td></tr>
            <tr><td style="color:#00E5FF;">EMAIL</td><td>@(string.IsNullOrEmpty(Model.Email) ? "N/A" : Model.Email)</td></tr>
            <tr><td style="color:#00E5FF;">ADDRESS</td><td>@(string.IsNullOrEmpty(Model.Address) ? "N/A" : Model.Address)</td></tr>
            <tr><td style="color:#00E5FF;">TAX CODE</td><td>@(string.IsNullOrEmpty(Model.TaxCode) ? "N/A" : Model.TaxCode)</td></tr>
            <tr><td style="color:#00E5FF;">BANK NAME</td><td>@(string.IsNullOrEmpty(Model.BankName) ? "N/A" : Model.BankName)</td></tr>
            <tr><td style="color:#00E5FF;">BANK ACCOUNT</td><td>@(string.IsNullOrEmpty(Model.BankAccount) ? "N/A" : Model.BankAccount)</td></tr>
            <tr><td style="color:#00E5FF;">WEBSITE</td><td>@(string.IsNullOrEmpty(Model.Website) ? "N/A" : Model.Website)</td></tr>
            <tr><td style="color:#00E5FF;">DEBT BALANCE</td><td style="color:@(Model.DebtBalance > 0 ? "#FF3333" : "#00FF66"); font-family:'VT323'; font-size:1.2rem;">@string.Format("{0:N0}", Model.DebtBalance)</td></tr>
            <tr><td style="color:#00E5FF;">DESCRIPTION</td><td>@(string.IsNullOrEmpty(Model.Description) ? "N/A" : Model.Description)</td></tr>
            <tr><td style="color:#00E5FF;">STATUS</td><td><span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">@(Model.IsActive ? "ACTIVE" : "INACTIVE")</span></td></tr>
        </table>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CLOSE</button>
    </div>
</div>
