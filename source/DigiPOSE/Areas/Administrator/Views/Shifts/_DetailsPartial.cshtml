@model DigiPOSE.Models.Shift
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-calendar-check text-cyan me-2"></i> SHIFT DETAILS</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
        <table class="table-cyber" style="font-family:'Roboto Mono'; font-size:0.9rem;">
            <tr><td style="color:#00E5FF; width:35%;">@Html.DisplayNameFor(model => model.ShiftId)</td><td>@Model.ShiftId</td></tr>
            <tr><td style="color:#00E5FF;">@Html.DisplayNameFor(model => model.User)</td><td style="font-weight:600;">@Model.User?.UserName</td></tr>
            <tr><td style="color:#00E5FF;">@Html.DisplayNameFor(model => model.Counter)</td><td>@Model.Counter?.CounterName</td></tr>
            <tr><td style="color:#00E5FF;">STATUS</td><td><span class="badge bg-info">@Model.Status?.StatusName</span></td></tr>
            <tr><td style="color:#00E5FF;">@Html.DisplayNameFor(model => model.StartTime)</td><td>@Model.StartTime.ToString("dd/MM/yyyy HH:mm")</td></tr>
            <tr><td style="color:#00E5FF;">END TIME</td><td>@(Model.EndTime.HasValue ? Model.EndTime.Value.ToString("dd/MM/yyyy HH:mm") : "Still Open")</td></tr>
            <tr><td style="color:#00E5FF;">START CASH</td><td style="color:#00FF66; font-family:'VT323'; font-size:1.2rem;">@string.Format("{0:N0}", Model.StartCash)</td></tr>
            <tr><td style="color:#00E5FF;">END CASH</td><td style="color:#00FF66; font-family:'VT323'; font-size:1.2rem;">@(Model.EndCash.HasValue ? string.Format("{0:N0}", Model.EndCash) : "---")</td></tr>
        </table>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CLOSE</button>
    </div>
</div>
