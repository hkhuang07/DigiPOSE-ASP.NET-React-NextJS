@model IEnumerable<DigiPOSE.Models.Shift>
@{ ViewData["Title"] = "Shift Management"; }
<div class="cyber-panel">
    <div class="cyber-panel-header">
        <div class="cyber-panel-title"><i class="fa-solid fa-calendar-check"></i> SHIFT MANAGEMENT</div>
        <div class="cyber-panel-sub">[WORKFORCE MODULE] // SHIFT REGISTRY</div>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <button type="button" class="btn-cyber-success btn-show-modal" data-url="@Url.Action("Create", "Shifts")"><i class="fa-solid fa-plus me-1"></i> ADD NEW SHIFT</button>
        <div style="font-family:'Roboto Mono'; font-size:0.85rem; color:#00E5FF; white-space:nowrap;">TOTAL RECORDS: <strong id="totalRecordsCount" style="color:#FFF; font-family:'VT323'; font-size:1.3rem;">--</strong></div>
    </div>
    <div class="table-responsive">
        <table id="datatable" class="table-cyber w-100">
            <thead>
                <tr>
                    <th style="width:5%; text-align:center; white-space:nowrap;">#</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.UserId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.CounterId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.StatusId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.StartTime)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.EndTime)</th>
                    <th style="white-space:nowrap; text-align:right;">@Html.DisplayNameFor(model => model.StartCash)</th>
                    <th style="width:120px; text-align:center; white-space:nowrap;">ACTIONS</th>
                </tr>
            </thead>
        </table>
    </div>
</div>
<div class="modal fade modal-cyber" id="globalModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" style="max-width:720px;" id="globalModalContainer"></div>
</div>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/lib/datatables/js/jquery.dataTables.min.js"></script>
    <script src="~/lib/datatables/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function(){
            var table = $('#datatable').DataTable({
                serverSide: true,
                processing: true,
                filter: true,
                ajax: {
                    url: '@Url.Action("Index_LoadData", "Shifts")',
                    type: "POST",
                    dataType: "JSON"
                },
                columns: [
                    { data: null, name: null, sortable: false, render: (d, t, r, meta) => meta.row + meta.settings._iDisplayStart + 1 },
                    { data: 'userName', name: 'User.UserName', render: d => d ? `<span style="color:#FFF; font-family:'Rajdhani'; font-weight:600;">${d}</span>` : '' },
                    { data: 'counterName', name: 'Counter.CounterName', render: d => d ? `<span style="color:#A0C0CE;">${d}</span>` : '' },
                    { data: 'statusName', name: 'Status.StatusName', render: d => d ? `<span class="badge bg-info">${d}</span>` : '' },
                    { data: 'startTime', name: 'StartTime', render: d => d ? `<span style="color:#A0C0CE; font-family:'Roboto Mono'; font-size:0.85rem;">${d.replace('T', ' ')}</span>` : '' },
                    { data: 'endTime', name: 'EndTime', render: d => d ? `<span style="color:#A0C0CE; font-family:'Roboto Mono'; font-size:0.85rem;">${d.replace('T', ' ')}</span>` : '<span style="color:#A0C0CE; font-family:\'Roboto Mono\'; font-size:0.85rem;">---</span>' },
                    { data: 'startCash', name: 'StartCash', render: d => d !== null ? `<span style="color:#00FF66; font-family:'VT323'; font-size:1.1rem; float:right;">${$.fn.dataTable.render.number(',', '.', 0, '').display(d)}</span>` : '' },
                    { 
                        data: null, 
                        searchable: false, 
                        orderable: false, 
                        render: function (d, t, r) { 
                            var detailsUrl = '@Url.Action("Details", "Shifts")/' + r.shiftId;
                            var editUrl = '@Url.Action("Edit", "Shifts")/' + r.shiftId;
                            var deleteUrl = '@Url.Action("Delete", "Shifts")/' + r.shiftId;
                            return '<button type="button" class="btn-cyber-primary btn-show-modal" data-url="' + detailsUrl + '" style="padding:4px 8px; font-size:0.75rem;"><i class="fa-solid fa-eye"></i></button> '
                                 + '<button type="button" class="btn-cyber-primary btn-show-modal" data-url="' + editUrl + '" style="padding:4px 8px; font-size:0.75rem; border-color:#FFB000; color:#FFB000;"><i class="fa-solid fa-pen-to-square"></i></button> ' 
                                 + '<button type="button" class="btn-cyber-danger btn-show-modal" data-url="' + deleteUrl + '" style="padding:4px 8px; font-size:0.75rem;"><i class="fa-solid fa-trash"></i></button>'; 
                        } 
                    }                        
                ],
                drawCallback: function (settings) {
                    var api = this.api();
                    var json = api.ajax.json();
                    if (json && json.recordsTotal !== undefined) {
                        $('#totalRecordsCount').text(json.recordsTotal);
                    }
                }
            });   
        });
    </script>
}
