@model IEnumerable<DigiPOSE.Models.StockVoucher>
@{ ViewData["Title"] = "Stock Vouchers"; }
<div class="cyber-panel">
    <div class="cyber-panel-header">
        <div class="cyber-panel-title"><i class="fa-solid fa-file-invoice"></i> STOCK VOUCHERS</div>
        <div class="cyber-panel-sub">[WAREHOUSE MODULE] // GOODS RECEIPT / DISPATCH LEDGER</div>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <button type="button" class="btn-cyber-success btn-show-modal" data-url="@Url.Action("Create", "StockVouchers")"><i class="fa-solid fa-plus me-1"></i> ADD NEW STOCK VOUCHER</button>
        <div style="font-family:'Roboto Mono'; font-size:0.85rem; color:#00E5FF; white-space:nowrap;">TOTAL RECORDS: <strong id="totalRecordsCount" style="color:#FFF; font-family:'VT323'; font-size:1.3rem;">--</strong></div>
    </div>
    <div class="table-responsive">
        <table id="datatable" class="table-cyber w-100">
            <thead>
                <tr>
                    <th style="width:5%; text-align:center; white-space:nowrap;">#</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.VoucherType)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.BranchId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.UserId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.SupplierId)</th>
                    <th style="white-space:nowrap; text-align:right;">@Html.DisplayNameFor(model => model.TotalValue)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.CreatedAt)</th>
                    <th style="width:120px; text-align:center; white-space:nowrap;">ACTIONS</th>
                </tr>
            </thead>
        </table>
    </div>
</div>
<div class="modal fade modal-cyber" id="globalModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" style="max-width:720px;" id="globalModalContainer"></div>
</div>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/lib/datatables/js/jquery.dataTables.min.js"></script>
    <script src="~/lib/datatables/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function(){
            var table = $('#datatable').DataTable({
                serverSide: true,
                processing: true,
                filter: true,
                ajax: {
                    url: '@Url.Action("Index_LoadData", "StockVouchers")',
                    type: "POST",
                    dataType: "JSON"
                },
                order: [[6, 'desc']], // Default order by CreatedAt descending
                columns: [
                    { data: null, name: null, sortable: false, render: (d, t, r, meta) => meta.row + meta.settings._iDisplayStart + 1 },
                    { 
                        data: 'voucherType', 
                        name: 'VoucherType', 
                        render: d => {
                            var badgeClass = d === "IN" ? "bg-success" : "bg-warning text-dark";
                            return `<span class="badge ${badgeClass}" style="font-family:'Rajdhani'; font-weight:600;">${d}</span>`;
                        }
                    },
                    { data: 'branchName', name: 'Branch.BranchName', render: d => `<span style="color:#A0C0CE;">${d}</span>` },
                    { data: 'userName', name: 'User.UserName', render: d => `<span style="color:#A0C0CE;">${d}</span>` },
                    { data: 'supplierName', name: 'Supplier.SupplierName', render: d => `<span style="color:#A0C0CE;">${d}</span>` },
                    { 
                        data: 'totalValue', 
                        name: 'TotalValue', 
                        render: d => `<span style="color:#00FF66; font-family:'VT323'; font-size:1.1rem; float:right;">${$.fn.dataTable.render.number(',', '.', 0, '').display(d)}</span>` 
                    },
                    { 
                        data: 'createdAt', 
                        name: 'CreatedAt', 
                        render: d => `<span style="color:#A0C0CE; font-family:'Roboto Mono'; font-size:0.82rem;">${d.replace('T', ' ')}</span>`
                    },
                    { 
                        data: null, 
                        searchable: false, 
                        orderable: false, 
                        render: function (d, t, r) { 
                            var detailsUrl = '@Url.Action("Details", "StockVouchers")/' + r.voucherId;
                            var editUrl = '@Url.Action("Edit", "StockVouchers")/' + r.voucherId;
                            var deleteUrl = '@Url.Action("Delete", "StockVouchers")/' + r.voucherId;
                            return '<div style="text-align:center;">'
                                 + '<button type="button" class="btn-cyber-info btn-show-modal" data-url="' + detailsUrl + '" style="padding:4px 8px; font-size:0.75rem; border-color:#00E5FF; color:#00E5FF;"><i class="fa-solid fa-circle-info"></i></button> '
                                 + '<button type="button" class="btn-cyber-primary btn-show-modal" data-url="' + editUrl + '" style="padding:4px 8px; font-size:0.75rem; border-color:#FFB000; color:#FFB000;"><i class="fa-solid fa-pen-to-square"></i></button> ' 
                                 + '<button type="button" class="btn-cyber-danger btn-show-modal" data-url="' + deleteUrl + '" style="padding:4px 8px; font-size:0.75rem;"><i class="fa-solid fa-trash"></i></button>'
                                 + '</div>'; 
                        } 
                    }                        
                ],
                drawCallback: function (settings) {
                    var api = this.api();
                    var json = api.ajax.json();
                    if (json && json.recordsTotal !== undefined) {
                        $('#totalRecordsCount').text(json.recordsTotal);
                    }
                }
            });   
        });
    </script>
}

