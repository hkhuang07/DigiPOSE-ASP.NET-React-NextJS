@model DigiPOSE.Models.StockVoucher
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-file-invoice text-cyan me-2"></i> STOCK VOUCHER DETAILS</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
        <table class="table-cyber" style="font-family:'Roboto Mono'; font-size:0.9rem;">
            <tr><td style="color:#00E5FF; width:40%;">VOUCHER ID</td><td>#@Model.VoucherId</td></tr>
            <tr><td style="color:#00E5FF;">VOUCHER TYPE</td><td><span class="badge @(Model.VoucherType == "IN" ? "bg-success" : "bg-warning text-dark")">@Model.VoucherType</span></td></tr>
            <tr><td style="color:#00E5FF;">@Html.DisplayNameFor(model => model.Branch)</td><td>@Model.Branch?.BranchName</td></tr>
            <tr><td style="color:#00E5FF;">@Html.DisplayNameFor(model => model.User)</td><td>@Model.User?.UserName</td></tr>
            <tr><td style="color:#00E5FF;">SUPPLIER</td><td>@(Model.Supplier?.SupplierName ?? "N/A")</td></tr>
            <tr><td style="color:#00E5FF;">TOTAL VALUE</td><td style="color:#00FF66; font-family:'VT323'; font-size:1.3rem;">@string.Format("{0:N0}", Model.TotalValue) VNĐ</td></tr>
            <tr><td style="color:#00E5FF;">@Html.DisplayNameFor(model => model.CreatedAt)</td><td>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td></tr>
        </table>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CLOSE</button>
    </div>
</div>
