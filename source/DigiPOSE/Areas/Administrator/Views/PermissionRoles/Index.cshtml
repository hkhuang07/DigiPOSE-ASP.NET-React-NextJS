@model IEnumerable<DigiPOSE.Models.PermissionRole>
@{ ViewData["Title"] = "Permission-Role Matrix"; }

<div class="cyber-panel">
    <div class="cyber-panel-header">
        <div class="cyber-panel-title"><i class="fa-solid fa-users-gear"></i> PERMISSION-ROLE MATRIX</div>
        <div class="cyber-panel-sub">[ACCESS CONTROL MODULE] // ASSIGNMENT MATRIX</div>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <button type="button" class="btn-cyber-success btn-show-modal" data-url="@Url.Action("Create", "PermissionRoles")">
            <i class="fa-solid fa-plus me-1"></i> ASSIGN PERMISSION TO ROLE
        </button>
        <div style="font-family:'Roboto Mono'; font-size:0.85rem; color:#00E5FF; white-space:nowrap;">
            TOTAL ASSIGNMENTS: <strong id="totalRecordsCount" style="color:#FFF; font-family:'VT323'; font-size:1.3rem;">--</strong>
        </div>
    </div>
    <div class="table-responsive">
        <table id="datatable" class="table-cyber w-100">
            <thead>
                <tr>
                    <th style="width:5%; text-align:center; white-space:nowrap;">#</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.RoleId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.PermissionId)</th>
                    <th style="white-space:nowrap;">Module Scope</th>
                    <th style="width:120px; text-align:center; white-space:nowrap;">ACTIONS</th>
                </tr>
            </thead>
        </table>
    </div>
</div>
<div class="modal fade modal-cyber" id="globalModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" style="max-width:620px;" id="globalModalContainer"></div>
</div>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/lib/datatables/js/jquery.dataTables.min.js"></script>
    <script src="~/lib/datatables/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function(){
            var table = $('#datatable').DataTable({
                serverSide: true,
                processing: true,
                filter: true,
                ajax: {
                    url: '@Url.Action("Index_LoadData", "PermissionRoles")',
                    type: "POST",
                    dataType: "JSON"
                },
                columns: [
                    { data: null, name: null, sortable: false, render: (d, t, r, meta) => meta.row + meta.settings._iDisplayStart + 1 },
                    { data: 'roleName', name: 'RoleId', render: d => `<span style="font-family:'Rajdhani'; font-weight:600; color:#00E5FF; white-space:nowrap;"><i class="fa-solid fa-user-shield me-2 text-cyan"></i>${d}</span>` },
                    { data: 'permissionName', name: 'PermissionId', render: d => `<span style="font-family:'Roboto Mono'; font-size:0.85rem; color:#FFF;">${d}</span>` },
                    { data: 'systemModule', name: 'SystemModule', render: d => `<span style="color:#FFB000; font-family:'Roboto Mono'; font-size:0.85rem;">[${d}]</span>` },
                    { 
                        data: null, 
                        searchable: false, 
                        orderable: false, 
                        render: function (d, t, r) { 
                            var deleteUrl = '@Url.Action("Delete", "PermissionRoles")?roleId=' + r.roleId + '&permissionId=' + r.permissionId;
                            return '<div style="text-align:center;">'
                                 + '<button type="button" class="btn-cyber-danger btn-show-modal" data-url="' + deleteUrl + '" style="padding:4px 8px; font-size:0.75rem;"><i class="fa-solid fa-trash"></i></button>'
                                 + '</div>'; 
                        } 
                    }                        
                ],
                drawCallback: function (settings) {
                    var api = this.api();
                    var json = api.ajax.json();
                    if (json && json.recordsTotal !== undefined) {
                        $('#totalRecordsCount').text(json.recordsTotal);
                    }
                }
            });   
        });
    </script>
}

