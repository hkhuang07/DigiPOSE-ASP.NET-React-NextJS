@model DigiPOSE.Models.PermissionRole
<div class="modal-content" style="border:1px solid #FF3333; box-shadow:0 0 15px rgba(255,51,51,0.2);">
    <div class="modal-header" style="border-bottom:1px solid rgba(255,51,51,0.3);">
        <h5 class="modal-title" style="color:#FF3333;"><i class="fa-solid fa-triangle-exclamation me-2"></i> SYSTEM WARNING</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="Delete" asp-controller="PermissionRoles" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="RoleId" />
        <input type="hidden" asp-for="PermissionId" />
        <div class="modal-body text-center">
            <div class="mb-3">
                <i class="fa-solid fa-radiation fa-3x" style="color:#FF3333; text-shadow:0 0 10px rgba(255,51,51,0.5);"></i>
            </div>
            <p style="font-family:'Rajdhani'; font-size:1.2rem; color:#FFF;">Are you sure you want to unassign this permission from the role?</p>
            <dl class="row text-start mt-3" style="font-family:'Roboto Mono'; font-size:0.9rem; margin-left: 20px;">
                <dt class="col-sm-5" style="color:#A0C0CE;">Role:</dt>
                <dd class="col-sm-7" style="color:#00E5FF; font-weight:bold;">@(Model.Role != null ? Model.Role.RoleName : "")</dd>
                <dt class="col-sm-5" style="color:#A0C0CE;">Permission:</dt>
                <dd class="col-sm-7" style="color:#FFF;">@(Model.Permission != null ? Model.Permission.PermissionName : "")</dd>
            </dl>
            <p style="font-family:'Roboto Mono'; font-size:0.85rem; color:#FF3333;">Users with this role will immediately lose access to this permission.</p>
        </div>
        <div class="modal-footer justify-content-center" style="border-top:1px solid rgba(255,51,51,0.3);">
            <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> ABORT</button>
            <button type="submit" class="btn-cyber-danger"><i class="fa-solid fa-trash me-1"></i> CONFIRM UNASSIGN</button>
        </div>
    </form>
</div>
