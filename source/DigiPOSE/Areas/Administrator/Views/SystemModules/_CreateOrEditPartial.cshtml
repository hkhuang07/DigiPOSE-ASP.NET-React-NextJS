@model DigiPOSE.Models.SystemModule
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-cogs text-cyan me-2"></i> @(Model.ModuleId == 0 ? "ADD NEW" : "EDIT") SYSTEM MODULE</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="@(Model.ModuleId == 0 ? "Create" : "Edit")" asp-controller="SystemModules" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ModuleId" />
        <div class="modal-body">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-family:'Roboto Mono'; font-size:0.85rem;"></div>
            <div class="mb-3">
                <label asp-for="ModuleName" class="form-cyber-label">@Html.DisplayNameFor(model => model.ModuleName) <span style="color:#FF3333;">*</span></label>
                <input asp-for="ModuleName" class="form-control form-cyber-control" placeholder="e.g. CRM, Analytics" />
                <span asp-validation-for="ModuleName" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Icon" class="form-cyber-label"></label>
                <input asp-for="Icon" class="form-control form-cyber-control" placeholder="e.g. fa-solid fa-users" />
                <span asp-validation-for="Icon" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="mb-3">
                <label asp-for="SortOrder" class="form-cyber-label"></label>
                <input asp-for="SortOrder" class="form-control form-cyber-control" />
                <span asp-validation-for="SortOrder" class="text-danger" style="font-family:'Roboto Mono'; font-size:0.8rem;"></span>
            </div>
            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" asp-for="IsActive" style="border-radius:0; border:1px solid #00E5FF; background-color:transparent;" />
                <label class="form-check-label text-cyan" style="font-family:'Roboto Mono'; font-size:0.9rem;" asp-for="IsActive">
                    @Html.DisplayNameFor(model => model.IsActive)
                </label>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CANCEL</button>
            <button type="submit" class="btn-cyber-success"><i class="fa-solid fa-floppy-disk me-1"></i> SAVE</button>
        </div>
    </form>
</div>
