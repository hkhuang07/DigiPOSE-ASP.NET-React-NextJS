@model IEnumerable<DigiPOSE.Models.SystemModule>
@{ ViewData["Title"] = "System Module Management"; }

<div class="cyber-panel">
    <div class="cyber-panel-header">
        <div class="cyber-panel-title"><i class="fa-solid fa-cogs"></i> SYSTEM MODULE MANAGEMENT</div>
        <div class="cyber-panel-sub">[CORE ARCHITECTURE] // MODULE REGISTRY</div>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <button type="button" class="btn-cyber-success btn-show-modal" data-url="@Url.Action("Create", "SystemModules")">
            <i class="fa-solid fa-plus me-1"></i> ADD NEW MODULE
        </button>
        <div style="font-family:'Roboto Mono'; font-size:0.85rem; color:#00E5FF; white-space:nowrap;">
            TOTAL RECORDS: <strong id="totalRecordsCount" style="color:#FFF; font-family:'VT323'; font-size:1.3rem;">--</strong>
        </div>
    </div>
    <div class="table-responsive">
        <table id="datatable" class="table-cyber w-100">
            <thead>
                <tr>
                    <th style="width:5%; text-align:center; white-space:nowrap;">#</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.ModuleName)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.Icon)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.SortOrder)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.IsActive)</th>
                    <th style="width:120px; text-align:center; white-space:nowrap;">ACTIONS</th>
                </tr>
            </thead>
        </table>
    </div>
</div>
<div class="modal fade modal-cyber" id="globalModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" style="max-width:620px;" id="globalModalContainer"></div>
</div>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/lib/datatables/js/jquery.dataTables.min.js"></script>
    <script src="~/lib/datatables/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function(){
            var table = $('#datatable').DataTable({
                serverSide: true,
                processing: true,
                filter: true,
                ajax: {
                    url: '@Url.Action("Index_LoadData", "SystemModules")',
                    type: "POST",
                    dataType: "JSON"
                },
                columns: [
                    { data: null, name: null, sortable: false, render: (d, t, r, meta) => meta.row + meta.settings._iDisplayStart + 1 },
                    { data: 'moduleName', name: 'ModuleName', render: d => `<span style="font-family:'Rajdhani'; font-weight:600; color:#FFF; white-space:nowrap;">${d}</span>` },
                    { data: 'icon', name: 'Icon', render: d => `<i class="${d} text-cyan"></i> ${d}` },
                    { data: 'sortOrder', name: 'SortOrder', render: d => `<span style="color:#FFB000; font-family:'Roboto Mono'; font-size:0.85rem;">[${d}]</span>` },
                    { data: 'isActive', name: 'IsActive', render: d => d ? `<span class="badge" style="background-color:rgba(0,255,102,0.1); border:1px solid #00FF66; color:#00FF66;">ACTIVE</span>` : `<span class="badge" style="background-color:rgba(255,51,51,0.1); border:1px solid #FF3333; color:#FF3333;">INACTIVE</span>` },
                    { 
                        data: null, 
                        searchable: false, 
                        orderable: false, 
                        render: function (d, t, r) { 
                            var detailsUrl = '@Url.Action("Details", "SystemModules")/' + r.moduleId;
                            var editUrl = '@Url.Action("Edit", "SystemModules")/' + r.moduleId;
                            var deleteUrl = '@Url.Action("Delete", "SystemModules")/' + r.moduleId;
                            return '<div style="text-align:center;">'
                                 + '<button type="button" class="btn-cyber-primary btn-show-modal" data-url="' + detailsUrl + '" style="padding:4px 8px; font-size:0.75rem;"><i class="fa-solid fa-eye"></i></button> '
                                 + '<button type="button" class="btn-cyber-primary btn-show-modal" data-url="' + editUrl + '" style="padding:4px 8px; font-size:0.75rem; border-color:#FFB000; color:#FFB000;"><i class="fa-solid fa-pen-to-square"></i></button> ' 
                                 + '<button type="button" class="btn-cyber-danger btn-show-modal" data-url="' + deleteUrl + '" style="padding:4px 8px; font-size:0.75rem;"><i class="fa-solid fa-trash"></i></button>'
                                 + '</div>'; 
                        } 
                    }                        
                ],
                drawCallback: function (settings) {
                    var api = this.api();
                    var json = api.ajax.json();
                    if (json && json.recordsTotal !== undefined) {
                        $('#totalRecordsCount').text(json.recordsTotal);
                    }
                }
            });   
        });
    </script>
}
