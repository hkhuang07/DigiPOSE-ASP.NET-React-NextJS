@model DigiPOSE.Models.Product
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-box-open text-cyan me-2"></i> PRODUCT DETAILS</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
        <div class="d-flex gap-4 mb-3">
            @if (!string.IsNullOrEmpty(Model.ImageUrl)) {
                <img src="~/uploads/products/@Model.ImageUrl" alt="@Model.ProductName"
                     style="width:100px; height:100px; object-fit:cover; border:1px solid #00E5FF; border-radius:6px; flex-shrink:0;" />
            } else {
                <div style="width:100px; height:100px; background:#0A0A0A; border:1px dashed #444; border-radius:6px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fa-solid fa-image" style="color:#444; font-size:2rem;"></i>
                </div>
            }
            <div style="flex:1;">
                <div style="font-family:'Rajdhani'; font-size:1.3rem; font-weight:700; color:#FFF;">@Model.ProductName</div>
                <div style="font-family:'Roboto Mono'; font-size:0.85rem; color:#00E5FF;">@Model.SKU</div>
                @if (!string.IsNullOrEmpty(Model.Slug)) {
                    <div style="font-family:'Roboto Mono'; font-size:0.8rem; color:#A0C0CE;">/products/@Model.Slug</div>
                }
                <div style="font-family:'VT323'; font-size:1.5rem; color:#00FF66; margin-top:4px;">@string.Format("{0:N0}", Model.BasePrice) VNĐ</div>
            </div>
        </div>
        <table class="table-cyber" style="font-family:'Roboto Mono'; font-size:0.9rem;">
            <tr><td style="color:#00E5FF; width:40%;">BARCODE</td><td>@(string.IsNullOrEmpty(Model.Barcode) ? "N/A" : Model.Barcode)</td></tr>
            <tr><td style="color:#00E5FF;">COST PRICE (GIÁ VỐN)</td><td style="color:#FFB000; font-family:'VT323'; font-size:1.2rem;">@string.Format("{0:N0}", Model.CostPrice) VNĐ</td></tr>
            <tr><td style="color:#00E5FF;">STOCK THRESHOLD</td><td>Min: @Model.MinStockLevel | Max: @Model.MaxStockLevel</td></tr>
            <tr><td style="color:#00E5FF;">@Html.DisplayNameFor(model => model.Category)</td><td>@Model.Category?.CategoryName</td></tr>
            <tr><td style="color:#00E5FF;">@Html.DisplayNameFor(model => model.ProductType)</td><td>@Model.ProductType?.TypeName</td></tr>
            <tr><td style="color:#00E5FF;">@Html.DisplayNameFor(model => model.Unit)</td><td>@Model.Unit?.UnitName</td></tr>
            <tr><td style="color:#00E5FF;">MANUFACTURER</td><td>@(Model.Manufacturer?.ManufacturerName ?? "N/A")</td></tr>
            <tr><td style="color:#00E5FF;">@Html.DisplayNameFor(model => model.TaxType)</td><td>@Model.TaxType?.TaxName</td></tr>
            <tr><td style="color:#00E5FF;">DESCRIPTION</td><td>@(string.IsNullOrEmpty(Model.Description) ? "N/A" : Model.Description)</td></tr>
            <tr><td style="color:#00E5FF;">STATUS</td><td><span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">@(Model.IsActive ? "ACTIVE" : "INACTIVE")</span></td></tr>
        </table>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CLOSE</button>
    </div>
</div>
