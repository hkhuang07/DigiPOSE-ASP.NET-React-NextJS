@model DigiPOSE.Models.Product
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-box-open text-cyan me-2"></i> PRODUCT DETAILS</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
        <div class="d-flex gap-4 mb-3">
            @if (!string.IsNullOrEmpty(Model.ImageUrl)) {
                <img src="~/uploads/products/@Model.ImageUrl" alt="@Model.ProductName"
                     style="width:100px; height:100px; object-fit:cover; border:1px solid #00E5FF; border-radius:6px; flex-shrink:0;" />
            } else {
                <div style="width:100px; height:100px; background:#0A0A0A; border:1px dashed #444; border-radius:6px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                    <i class="fa-solid fa-image" style="color:#444; font-size:2rem;"></i>
                </div>
            }
            <div style="flex:1;">
                <div style="font-family:'Rajdhani'; font-size:1.3rem; font-weight:700; color:#FFF;">@Model.ProductName</div>
                <div style="font-family:'Roboto Mono'; font-size:0.85rem; color:#00E5FF;">@Model.SKU</div>
                @if (!string.IsNullOrEmpty(Model.Slug)) {
                    <div style="font-family:'Roboto Mono'; font-size:0.8rem; color:#A0C0CE;">/products/@Model.Slug</div>
                }
                <div style="font-family:'VT323'; font-size:1.5rem; color:#00FF66; margin-top:4px;">@string.Format("{0:N0}", Model.BasePrice) VNĐ</div>
            </div>
        </div>
        <div style="background: rgba(0, 0, 0, 0.6); border: 1px solid rgba(0, 229, 255, 0.3); padding: 1.25rem;">
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">BARCODE:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#FFF;">@(string.IsNullOrEmpty(Model.Barcode) ? "N/A" : Model.Barcode)</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">COST PRICE (GIÁ VỐN):</div>
                <div class="col-8" style="font-family:'VT323'; font-size:1.4rem; color:#FFB000;">@string.Format("{0:N0}", Model.CostPrice) VNĐ</div>
            </div>

            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">CATEGORY:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#FFF;">@(Model.Category != null ? Model.Category.CategoryName : "N/A")</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">PRODUCT TYPE:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#FFF;">@(Model.ProductType != null ? Model.ProductType.TypeName : "N/A")</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">UNIT:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#FFF;">@(Model.Unit != null ? Model.Unit.UnitName : "N/A")</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">MANUFACTURER:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#FFF;">@(Model.Manufacturer != null ? Model.Manufacturer.ManufacturerName : "N/A")</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">TAX TYPE:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#FFF;">@(Model.TaxType != null ? Model.TaxType.TaxName : "N/A")</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">STATUS:</div>
                <div class="col-8"><span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">@(Model.IsActive ? "ACTIVE" : "INACTIVE")</span></div>
            </div>
            <div class="row mt-3 pt-3" style="border-top: 1px dashed rgba(0, 229, 255, 0.3);">
                <div class="col-12" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase; margin-bottom:10px;">DESCRIPTION:</div>
                <div class="col-12" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#A0C0CE; word-break:break-word;">
                    @(string.IsNullOrEmpty(Model.Description) || Model.Description.Contains("NO Description") ? Html.Raw("N/A") : Html.Raw(Model.Description))
                </div>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn-cyber-cancel" data-bs-dismiss="modal" style="border-top: 1px solid aliceblue !important; border-bottom: 1px solid aliceblue !important; border-left: none !important; border-right: none !important; color: aliceblue !important; background: #222222 !important;"><i class="fa-solid fa-xmark me-1"></i> CLOSE</button>
    </div>
</div>

