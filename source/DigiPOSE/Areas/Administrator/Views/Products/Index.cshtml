@section Styles {
    <link rel="stylesheet" href="~/lib/datatables/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/lib/datatables/css/buttons.bootstrap5.min.css" />
}

@model IEnumerable<DigiPOSE.Models.Product>
@{
     ViewData["Title"] = "Product Catalog"; 
}

<div class="cyber-panel">
    <div class="cyber-panel-header">
        <div class="cyber-panel-title"><i class="fa-solid fa-box-open"></i> PRODUCT CATALOG</div>
        <div class="cyber-panel-sub">[INVENTORY MODULE] // PRODUCT REGISTRY</div>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <button type="button" class="btn-cyber-success btn-show-modal" data-url="@Url.Action("Create", "Products")">
            <i class="fa-solid fa-plus me-1"></i> ADD NEW PRODUCT
        </button>
        <div style="font-family:'Roboto Mono'; font-size:0.85rem; color:#00E5FF; white-space:nowrap;">
            TOTAL RECORDS: <strong id="totalRecordsCount" style="color:#FFF; font-family:'VT323'; font-size:1.3rem;">--</strong>
        </div>
    </div>
    <div class="table-responsive">
        <table id="datatable" class="table-cyber w-100">
            <thead>
                <tr>
                    <th style="width:5%; text-align:center; white-space:nowrap;">#</th>
                    <th style="width:50px; white-space:nowrap;">@Html.DisplayNameFor(model => model.ImageUrl)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.SKU)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.Slug)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.ProductName)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.ProductTypeId)</th> 
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.CategoryId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.ManufacturerId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.TaxTypeId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.UnitId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.Barcode)</th>
                    <th style="white-space:nowrap; text-align:right;">@Html.DisplayNameFor(model => model.BasePrice)</th>
                    <th style="white-space:nowrap; text-align:right;">@Html.DisplayNameFor(model => model.CostPrice)</th>
                    <th style="white-space:nowrap; text-align:right;">@Html.DisplayNameFor(model => model.MinStockLevel)</th>
                    <th style="white-space:nowrap; text-align:right;">@Html.DisplayNameFor(model => model.MaxStockLevel)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.IsActive)</th>
                    <th style="width:120px; text-align:center; white-space:nowrap;">ACTIONS</th>
                </tr>
            </thead>
        </table>
    </div>
</div>

<div class="modal fade modal-cyber" id="globalModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" style="max-width:780px;" id="globalModalContainer"></div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/lib/datatables/js/jquery.dataTables.min.js"></script>
    <script src="~/lib/datatables/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function(){
            var table = $('#datatable').DataTable({
                serverSide: true,
                processing: true,
                filter: true,
                ajax: {
                    url: '@Url.Action("Index_LoadData", "Products",new { Area = "Administrator" })',
                    type: "POST",
                    dataType: "JSON"
                },
                columns: [
                    { data: null, name: null, sortable: false, render: (d, t, r, meta) => meta.row + meta.settings._iDisplayStart + 1 },
                    {
                        data: 'imageUrl',
                        name: 'ImageUrl',
                        searchable: false,
                        orderable: false,
                        render: function (d) {
                            if (d) return `<img src="/uploads/products/${d}" style="width:38px; height:38px; object-fit:cover; border:1px solid #00E5FF; border-radius:4px;" />`;
                            return `<div style="width:38px; height:38px; background:#0A0A0A; border:1px dashed #444; border-radius:4px; display:flex; align-items:center; justify-content:center;"><i class="fa-solid fa-image text-muted"></i></div>`;
                        }
                    },
                    { data: 'sku', name: 'SKU' },
                    { data: 'slug', name: 'Slug' },
                    { data: 'productName', name: 'ProductName' },
                    { data: 'productTypeName', name: 'ProductType.ProductTypeName' },
                    { data: 'categoryName', name: 'Category.CategoryName' },
                    { data: 'manufacturerName', name: 'Manufacturer.ManufacturerName' },
                    { data: 'taxTypeName', name: 'TaxType.TypeName' },
                    { data: 'unitName', name: 'Unit.UnitName' },
                    { data: 'barcode', name: 'Barcode' },
                    { data: 'basePrice', name: 'BasePrice', render: $.fn.dataTable.render.number(',', '.', 0, '') },
                    { data: 'costPrice', name: 'CostPrice', render: $.fn.dataTable.render.number(',', '.', 0, '') },
                    { data: 'minStockLevel', name: 'MinStockLevel' },
                    { data: 'maxStockLevel', name: 'MaxStockLevel' },
                    { 
                        data: 'isActive', 
                        name: 'IsActive',
                        render: d => d ? '<span class="badge bg-success">ACTIVE</span>' : '<span class="badge bg-secondary">INACTIVE</span>'
                    },                            
                    { 
                        data: null, 
                        searchable: false, 
                        orderable: false, 
                        render: function (d, t, r) { 
                            var editUrl = '@Url.Action("Edit", "Products")/' + r.productId;
                            var deleteUrl = '@Url.Action("Delete", "Products")/' + r.productId;
                            return '<button class="btn-cyber-primary btn-show-modal" data-url="' + editUrl + '" style="padding:4px 8px; font-size:0.75rem; border-color:#FFB000; color:#FFB000;"><i class="fa-solid fa-pen-to-square"></i></button> ' 
                                 + '<button class="btn-cyber-danger btn-show-modal" data-url="' + deleteUrl + '" style="padding:4px 8px; font-size:0.75rem;"><i class="fa-solid fa-trash"></i></button>'; 
                        } 
                    }                        
                ],
                drawCallback: function (settings) {
                    var api = this.api();
                    var json = api.ajax.json();
                    if (json && json.recordsTotal !== undefined) {
                        $('#totalRecordsCount').text(json.recordsTotal);
                    }
                }
            });   
        });
    </script>
    <script>
        $(document).on('shown.bs.modal', '#globalModal', function () {
            var descEl = document.querySelector('#Description');
            if (descEl && !descEl.classList.contains('ck-initialized')) {
                ClassicEditor
                    .create(descEl)
                    .then(editor => {
                        descEl.classList.add('ck-initialized');
                        // Đồng bộ nội dung HTML từ CKEditor về <textarea> trước khi Submit Form AJAX
                        $('#productForm').off('submit.ckeditor').on('submit.ckeditor', function () {
                            descEl.value = editor.getData();
                        });
                    })
                    .catch(err => console.error('CKEditor initialization error:', err));
            }
        }); 
    </script>
}
