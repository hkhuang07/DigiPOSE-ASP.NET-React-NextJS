@model DigiPOSE.Models.Customer
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-user-group text-cyan me-2"></i> CUSTOMER DETAILS</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
        <table class="table-cyber" style="font-family:'Roboto Mono'; font-size:0.9rem;">
            <tr><td style="color:#00E5FF; width:35%;">CUSTOMER ID</td><td>@Model.CustomerId</td></tr>
            <tr><td style="color:#00E5FF;">FULL NAME</td><td style="font-weight:600;">@Model.FullName</td></tr>
            <tr><td style="color:#00E5FF;">COMPANY NAME</td><td style="font-weight:600; color:#00FF66;">@Model.CompanyName</td></tr>
            <tr><td style="color:#00E5FF;">TYPE</td><td>@Model.CustomeType?.TypeName</td></tr>
            <tr><td style="color:#00E5FF;">PHONE</td><td>@Model.PhoneNumber</td></tr>
            <tr><td style="color:#00E5FF;">EMAIL</td><td>@Model.Email</td></tr>
            <tr><td style="color:#00E5FF;">TAX CODE (MST)</td><td style="color:#FFB000; font-weight:600;">@Model.TaxCode</td></tr>
            <tr><td style="color:#00E5FF;">BUDGET CODE (ĐVNS)</td><td>@Model.BudgetCode</td></tr>
            <tr><td style="color:#00E5FF;">ID NO (CCCD)</td><td>@Model.IdNo</td></tr>
            <tr><td style="color:#00E5FF;">BANK NAME</td><td>@Model.BankName</td></tr>
            <tr><td style="color:#00E5FF;">BANK ACCOUNT</td><td>@Model.BankAccount</td></tr>
            <tr><td style="color:#00E5FF;">ADDRESS</td><td>@Model.Address</td></tr>
            <tr><td style="color:#00E5FF;">REWARD POINTS</td><td style="color:#00FF66; font-family:'VT323'; font-size:1.2rem;">@Model.RewardPoints</td></tr>
            <tr><td style="color:#00E5FF;">DEBT BALANCE</td><td style="color:@(Model.DebtBalance > 0 ? "#FF3333" : "#00FF66"); font-family:'VT323'; font-size:1.2rem;">@string.Format("{0:N0}", Model.DebtBalance)</td></tr>
            <tr><td style="color:#00E5FF;">NOTES</td><td>@(string.IsNullOrEmpty(Model.Notes) ? "N/A" : Model.Notes)</td></tr>
            <tr><td style="color:#00E5FF;">STATUS</td><td><span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">@(Model.IsActive ? "ACTIVE" : "INACTIVE")</span></td></tr>
        </table>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal"><i class="fa-solid fa-xmark me-1"></i> CLOSE</button>
    </div>
</div>
