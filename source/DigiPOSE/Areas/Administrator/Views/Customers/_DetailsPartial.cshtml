@model DigiPOSE.Models.Customer
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-user-group text-cyan me-2"></i> CUSTOMER DETAILS</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
        <div style="background: rgba(0, 0, 0, 0.6); border: 1px solid rgba(0, 229, 255, 0.3); padding: 1.25rem;">
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">CUSTOMER ID:</div>
                <div class="col-8" style="font-family:'VT323'; font-size:1.4rem; color:#FFF;">#@Model.CustomerId.ToString("D4")</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">FULL NAME:</div>
                <div class="col-8" style="font-family:'Rajdhani'; font-size:1.1rem; font-weight:bold; color:#FFF;">@Model.FullName</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">COMPANY NAME:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#00FF66; font-weight:600;">@(string.IsNullOrEmpty(Model.CompanyName) ? "N/A" : Model.CompanyName)</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">TYPE:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#FFF;">@(Model.CustomeType != null ? Model.CustomeType.TypeName : "N/A")</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">PHONE:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#FFF;">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "N/A" : Model.PhoneNumber)</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">EMAIL:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#A0C0CE; word-break:break-word;">@(string.IsNullOrEmpty(Model.Email) ? "N/A" : Model.Email)</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">TAX CODE (MST):</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#FFB000; font-weight:600;">@(string.IsNullOrEmpty(Model.TaxCode) ? "N/A" : Model.TaxCode)</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">BUDGET CODE (ĐVNS):</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#FFF;">@(string.IsNullOrEmpty(Model.BudgetCode) ? "N/A" : Model.BudgetCode)</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">ID NO (CCCD):</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#FFF;">@(string.IsNullOrEmpty(Model.IdNo) ? "N/A" : Model.IdNo)</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">BANK NAME:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#FFF;">@(string.IsNullOrEmpty(Model.BankName) ? "N/A" : Model.BankName)</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">BANK ACCOUNT:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#FFF;">@(string.IsNullOrEmpty(Model.BankAccount) ? "N/A" : Model.BankAccount)</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">ADDRESS:</div>
                <div class="col-8" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#FFF; word-break:break-word;">@(string.IsNullOrEmpty(Model.Address) ? "N/A" : Model.Address)</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">REWARD POINTS:</div>
                <div class="col-8" style="font-family:'VT323'; font-size:1.4rem; color:#00FF66;">@Model.RewardPoints</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">DEBT BALANCE:</div>
                <div class="col-8" style="font-family:'VT323'; font-size:1.4rem; color:@(Model.DebtBalance > 0 ? "#FF3333" : "#00FF66");">@string.Format("{0:N0}", Model.DebtBalance)</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">STATUS:</div>
                <div class="col-8"><span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">@(Model.IsActive ? "ACTIVE" : "INACTIVE")</span></div>
            </div>
            <div class="row mt-3 pt-3" style="border-top: 1px dashed rgba(0, 229, 255, 0.3);">
                <div class="col-12" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase; margin-bottom:10px;">NOTES:</div>
                <div class="col-12" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#A0C0CE; word-break:break-word;">
                    @(string.IsNullOrEmpty(Model.Notes) || Model.Notes.Contains("NO Notes") ? Html.Raw("N/A") : Html.Raw(Model.Notes))
                </div>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn-cyber-cancel" data-bs-dismiss="modal" style="border-top: 1px solid aliceblue !important; border-bottom: 1px solid aliceblue !important; border-left: none !important; border-right: none !important; color: aliceblue !important; background: #222222 !important;"><i class="fa-solid fa-xmark me-1"></i> CLOSE</button>
    </div>
</div>

