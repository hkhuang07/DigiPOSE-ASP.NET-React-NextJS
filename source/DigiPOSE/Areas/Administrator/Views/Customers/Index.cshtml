@model IEnumerable<DigiPOSE.Models.Customer>
@{ ViewData["Title"] = "Customer Management"; }
<div class="cyber-panel">
    <div class="cyber-panel-header">
        <div class="cyber-panel-title"><i class="fa-solid fa-user-group"></i> CUSTOMER MANAGEMENT</div>
        <div class="cyber-panel-sub">[CRM MODULE] // CUSTOMER REGISTRY</div>
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <button type="button" class="btn-cyber-success btn-show-modal" data-url="@Url.Action("Create", "Customers")"><i class="fa-solid fa-plus me-1"></i> ADD NEW CUSTOMER</button>
        <div style="font-family:'Roboto Mono'; font-size:0.85rem; color:#00E5FF; white-space:nowrap;">TOTAL RECORDS: <strong id="totalRecordsCount" style="color:#FFF; font-family:'VT323'; font-size:1.3rem;">--</strong></div>
    </div>
    <div class="table-responsive">
        <table id="datatable" class="table-cyber w-100">
            <thead>
                <tr>
                    <th style="width:5%; text-align:center; white-space:nowrap;">#</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.FullName)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.CustomeTypeId)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.PhoneNumber)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.Email)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.RewardPoints)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.DebtBalance)</th>
                    <th style="white-space:nowrap;">@Html.DisplayNameFor(model => model.IsActive)</th>
                    <th style="width:120px; text-align:center; white-space:nowrap;">ACTIONS</th>
                </tr>
            </thead>
        </table>
    </div>
</div>
<div class="modal fade modal-cyber" id="globalModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered" style="max-width:720px;" id="globalModalContainer"></div>
</div>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script src="~/lib/datatables/js/jquery.dataTables.min.js"></script>
    <script src="~/lib/datatables/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function(){
            var table = $('#datatable').DataTable({
                serverSide: true,
                processing: true,
                filter: true,
                ajax: {
                    url: '@Url.Action("Index_LoadData", "Customers")',
                    type: "POST",
                    dataType: "JSON"
                },
                columns: [
                    { data: null, name: null, sortable: false, render: (d, t, r, meta) => meta.row + meta.settings._iDisplayStart + 1 },
                    { data: 'fullName', name: 'FullName', render: d => `<i class="fa-solid fa-user-circle me-2 text-cyan"></i><span style="font-family:'Rajdhani'; font-weight:600; color:#FFF;">${d}</span>` },
                    { data: 'customeTypeName', name: 'CustomeType.TypeName', render: d => d ? `<span style="color:#A0C0CE;">${d}</span>` : '' },
                    { data: 'phoneNumber', name: 'PhoneNumber', render: d => d ? `<span style="color:#A0C0CE;">${d}</span>` : '' },
                    { data: 'email', name: 'Email', render: d => d ? `<div style="color:#A0C0CE; max-width:150px; overflow:hidden; text-overflow:ellipsis;" title="${d}">${d}</div>` : '' },
                    { data: 'rewardPoints', name: 'RewardPoints', render: d => `<span style="color:#00FF66; font-family:'VT323'; font-size:1.2rem; display:block; text-align:center;">${d}</span>` },
                    { data: 'debtBalance', name: 'DebtBalance', render: $.fn.dataTable.render.number(',', '.', 0, '') },
                    { 
                        data: 'isActive', 
                        name: 'IsActive',
                        render: (d, t, r) => {
                            var antiForgery = $('input[name="__RequestVerificationToken"]').val() || '';
                            return `<form class="toggle-active-form" action="/Administrator/Customers/ToggleActive/${r.customerId}" method="post" style="display:inline; text-align:center;">
                                        <input name="__RequestVerificationToken" type="hidden" value="${antiForgery}" />
                                        <button type="submit" class="badge ${d ? "bg-success" : "bg-secondary"} border-0" style="cursor:pointer; font-size:0.75rem; padding:4px 8px;" title="Click to toggle status">
                                            ${d ? "ACTIVE" : "INACTIVE"}
                                        </button>
                                    </form>`;
                        }
                    },                            
                    { 
                        data: null, 
                        searchable: false, 
                        orderable: false, 
                        render: function (d, t, r) { 
                            var detailsUrl = '@Url.Action("Details", "Customers")/' + r.customerId;
                            var editUrl = '@Url.Action("Edit", "Customers")/' + r.customerId;
                            var deleteUrl = '@Url.Action("Delete", "Customers")/' + r.customerId;
                            return '<div style="text-align:center;">'
                                 + '<button type="button" class="btn-cyber-info btn-show-modal" data-url="' + detailsUrl + '" style="padding:4px 8px; font-size:0.75rem; border-color:#00E5FF; color:#00E5FF;"><i class="fa-solid fa-circle-info"></i></button> '
                                 + '<button type="button" class="btn-cyber-primary btn-show-modal" data-url="' + editUrl + '" style="padding:4px 8px; font-size:0.75rem; border-color:#FFB000; color:#FFB000;"><i class="fa-solid fa-pen-to-square"></i></button> ' 
                                 + '<button type="button" class="btn-cyber-danger btn-show-modal" data-url="' + deleteUrl + '" style="padding:4px 8px; font-size:0.75rem;"><i class="fa-solid fa-trash"></i></button>'
                                 + '</div>'; 
                        } 
                    }                        
                ],
                drawCallback: function (settings) {
                    var api = this.api();
                    var json = api.ajax.json();
                    if (json && json.recordsTotal !== undefined) {
                        $('#totalRecordsCount').text(json.recordsTotal);
                    }
                }
            });   
        });

        $(document).on('shown.bs.modal', '#globalModal', function () {
            var descEl = document.querySelector('#Notes');
            if (descEl && !descEl.classList.contains('ck-initialized')) {
                ClassicEditor
                    .create(descEl)
                    .then(editor => {
                        descEl.classList.add('ck-initialized');
                        $(descEl).closest('form').off('submit.ckeditor').on('submit.ckeditor', function () {
                            descEl.value = editor.getData();
                        });
                    })
                    .catch(err => console.error('CKEditor initialization error:', err));
            }
        }); 
    </script>
}

