@model DigiPOSE.Models.OrderDetail

<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-list-ol text-cyan me-2"></i> @(Model.OrderDetailId == 0 ? "ADD NEW" : "EDIT") ORDER LINE</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="ajax-modal-form" asp-action="@(Model.OrderDetailId == 0 ? "Create" : "Edit")" asp-controller="OrderDetails" >
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="OrderDetailId" />
        <div class="modal-body">
            <div class="mb-3">
                <label asp-for="OrderId" class="form-cyber-label">@Html.DisplayNameFor(model => model.OrderId) <span style="color:#FF3333;">*</span></label>
                <select asp-for="OrderId" asp-items="ViewBag.OrderId" class="form-control form-cyber-control"></select>
                <span asp-validation-for="OrderId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ProductId" class="form-cyber-label">@Html.DisplayNameFor(model => model.ProductId) <span style="color:#FF3333;">*</span></label>
                <select asp-for="ProductId" asp-items="ViewBag.ProductId" class="form-control form-cyber-control"></select>
                <span asp-validation-for="ProductId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="NatureId" class="form-cyber-label">@Html.DisplayNameFor(model => model.NatureId) <span style="color:#FF3333;">*</span></label>
                <select asp-for="NatureId" asp-items="ViewBag.NatureId" class="form-control form-cyber-control"></select>
                <span asp-validation-for="NatureId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TaxTypeId" class="form-cyber-label">@Html.DisplayNameFor(model => model.TaxTypeId) <span style="color:#FF3333;">*</span></label>
                <select asp-for="TaxTypeId" asp-items="ViewBag.TaxTypeId" class="form-control form-cyber-control"></select>
                <span asp-validation-for="TaxTypeId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ProductName" class="form-cyber-label"></label>
                <input asp-for="ProductName" class="form-control form-cyber-control" />
                <span asp-validation-for="ProductName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="UnitName" class="form-cyber-label"></label>
                <input asp-for="UnitName" class="form-control form-cyber-control" />
                <span asp-validation-for="UnitName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Quantity" class="form-cyber-label">@Html.DisplayNameFor(model => model.Quantity) <span style="color:#FF3333;">*</span></label>
                <input asp-for="Quantity" class="form-control form-cyber-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="UnitPrice" class="form-cyber-label">@Html.DisplayNameFor(model => model.UnitPrice) <span style="color:#FF3333;">*</span></label>
                <input asp-for="UnitPrice" class="form-control form-cyber-control" />
                <span asp-validation-for="UnitPrice" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DiscountRate" class="form-cyber-label"></label>
                <input asp-for="DiscountRate" class="form-control form-cyber-control" />
                <span asp-validation-for="DiscountRate" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DiscountAmount" class="form-cyber-label"></label>
                <input asp-for="DiscountAmount" class="form-control form-cyber-control" />
                <span asp-validation-for="DiscountAmount" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TaxRate" class="form-cyber-label"></label>
                <input asp-for="TaxRate" class="form-control form-cyber-control" />
                <span asp-validation-for="TaxRate" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TaxAmount" class="form-cyber-label"></label>
                <input asp-for="TaxAmount" class="form-control form-cyber-control" />
                <span asp-validation-for="TaxAmount" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TotalAmount" class="form-cyber-label"></label>
                <input asp-for="TotalAmount" class="form-control form-cyber-control" readonly />
                <span asp-validation-for="TotalAmount" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-cyber-label"></label>
                <input asp-for="Notes" class="form-control form-cyber-control" />
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="IsFree" class="form-check-input" />
                <label asp-for="IsFree" class="form-cyber-label ms-2"></label>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn-cyber-primary" data-bs-dismiss="modal">CANCEL</button>
            <button type="submit" class="btn-cyber-success">SAVE</button>
        </div>
    </form>
</div>

