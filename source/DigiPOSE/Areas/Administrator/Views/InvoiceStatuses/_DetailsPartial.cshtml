@model DigiPOSE.Models.InvoiceStatus
<div class="modal-content">
    <div class="modal-header">
        <h5 class="modal-title"><i class="fa-solid fa-file-circle-check text-cyan me-2"></i> INVOICESTATUS DETAILS</h5>
        <button type="button" class="btn-close-cyber" data-bs-dismiss="modal"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
        <div style="background: rgba(0, 0, 0, 0.6); border: 1px solid rgba(0, 229, 255, 0.3); padding: 1.25rem;">
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">STATUS ID:</div>
                <div class="col-8" style="font-family:'VT323'; font-size:1.4rem; color:#FFF;">#@Model.InvoiceStatusId.ToString("D4")</div>
            </div>
            <div class="row mb-3 align-items-center">
                <div class="col-4" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase;">STATUS NAME:</div>
                <div class="col-8" style="font-family:'Rajdhani'; font-size:1.1rem; font-weight:bold; color:#FFF;">@Model.StatusName</div>
            </div>
            <div class="row mt-3 pt-3" style="border-top: 1px dashed rgba(0, 229, 255, 0.3);">
                <div class="col-12" style="color:#00E5FF; font-family:'Orbitron'; font-size:0.75rem; text-transform:uppercase; margin-bottom:10px;">DESCRIPTION:</div>
                <div class="col-12" style="font-family:'Roboto Mono'; font-size:0.9rem; color:#A0C0CE; word-break:break-word;">
                    @(string.IsNullOrEmpty(Model.Description) || Model.Description == "<p>NO Description</p>" ? Html.Raw("N/A") : Html.Raw(Model.Description))
                </div>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn-cyber-cancel" data-bs-dismiss="modal">
            <i class="fa-solid fa-xmark me-1"></i> CLOSE
        </button>
    </div>
</div>

